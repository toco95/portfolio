---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Image URLs to preload via `<link rel="preload">`. Use for hero/above-fold
      images that must paint immediately (e.g. the design splash preview). */
  preloadImages?: string[];
}

const {
  title = 'Thomas Cochet — Product Designer',
  description = 'Product Designer based in Paris, France.',
  preloadImages = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/images/projects/misc/opengraph.jpg', Astro.site ?? 'https://thomascochet.com').toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/images/projects/misc/opengraph.jpg', Astro.site ?? 'https://thomascochet.com').toString()} />

    <link rel="icon" type="image/webp" href="/images/icons/profile.webp" />
    {preloadImages.map((href) => (
      <link rel="preload" as="image" href={href} />
    ))}
    <title>{title}</title>

    {/* Apply saved theme + intro gating before first paint, and re-apply across view-transition swaps. */}
    <script is:inline>
      (function () {
        function resolveTheme() {
          try {
            var stored = localStorage.getItem('theme');
            if (stored) return stored;
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'midnight' : 'noon';
          } catch (e) {
            return 'noon';
          }
        }

        // Per-route intro gating. Each route gets its own session marker; the
        // matching class is added to <html> before paint so CSS animations only
        // apply on the first visit per session.
        function applyIntroGating(htmlEl, pathname, hash) {
          try {
            if (pathname === '/' && !sessionStorage.getItem('aboutIntroSeen')) {
              htmlEl.classList.add('intro-active');
            }
            // First /design visit takes over with a splash screen — pre-mark
            // the blur intro as seen so it doesn't stack behind the splash on
            // first load. The splash component handles its own session marker
            // (designSplashSeen) once dismissed. The `design-splash-active`
            // class is applied pre-paint so the splash covers the canvas on the
            // first frame instead of fading in via JS (which let the canvas
            // flash through).
            //
            // A hash deep-link (e.g. /design#hyperline from a "See the work"
            // link) is an explicit request for a specific project, so skip the
            // splash entirely: mark it seen (so DesignSplash removes itself) and
            // let the canvas blur-fade in already focused on that frame.
            // canvas.ts reads the same hash to fit the viewport to the target
            // rect.
            var deepLink = !!(hash && hash.length > 1);
            if (pathname.startsWith('/design') && !sessionStorage.getItem('designSplashSeen')) {
              if (deepLink) {
                sessionStorage.setItem('designSplashSeen', '1');
              } else {
                sessionStorage.setItem('designIntroSeen', '1');
                htmlEl.classList.add('design-splash-active');
              }
            }
            if (pathname.startsWith('/design') && !sessionStorage.getItem('designIntroSeen')) {
              htmlEl.classList.add('design-intro-active');
            }
          } catch (e) {}
        }

        document.documentElement.dataset.theme = resolveTheme();
        applyIntroGating(document.documentElement, window.location.pathname, window.location.hash);

        document.addEventListener('astro:before-swap', function (e) {
          e.newDocument.documentElement.dataset.theme = resolveTheme();
          var toUrl = e.to ? new URL(e.to, window.location.origin) : window.location;
          applyIntroGating(e.newDocument.documentElement, toUrl.pathname, toUrl.hash);
        });

        // Mobile + /design: force a full page reload instead of using view
        // transitions. View transitions don't fully release the previous
        // /design's DOM, decoded image bitmaps, and panzoom GPU layer before
        // the new /design DOM mounts, so the second visit pushes iOS Safari
        // over its per-tab memory ceiling and triggers the "can't open this
        // page" kill. A real navigation gives the new visit a clean memory
        // slate. Initial page loads aren't affected (no view transition).
        document.addEventListener('astro:before-preparation', function (e) {
          if (!window.matchMedia('(max-width: 768px)').matches) return;
          if (!e.to) return;
          var toUrl = new URL(e.to, window.location.origin);
          if (toUrl.pathname.startsWith('/design')) {
            e.preventDefault();
            window.location.assign(toUrl.toString());
          }
        });
      })();
    </script>

    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>
