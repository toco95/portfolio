---
import BaseLayout from './BaseLayout.astro';
import Button from '../components/Button.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  date: Date;
  cover?: string;
}

const { title, description, category, date, cover } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});

/* Phosphor Light – ArrowLeft (16×16) */
const arrowLeft = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor"><path d="M222,128a6,6,0,0,1-6,6H54.49l61.75,61.76a6,6,0,1,1-8.48,8.48l-72-72a6,6,0,0,1,0-8.48l72-72a6,6,0,0,1,8.48,8.48L54.49,122H216A6,6,0,0,1,222,128Z"/></svg>`;
---

<BaseLayout title={`${title} — Thomas Cochet`} description={description}>
  <article class="py-0">
    <Button href="/" label="Back" iconLeft={arrowLeft} />

    <header class="mt-8">
      <h1 class="text-2xl font-medium">{title}</h1>
      <p class="mt-2 text-xl text-text-secondary">{description}</p>
      <p class="mt-2 text-base text-text-tertiary">{category} — {formattedDate}</p>
    </header>

    {cover && (
      <img src={cover} alt={title} class="mt-8 w-full h-auto rounded-md" />
    )}

    <div class="prose mt-10">
      <slot />
    </div>
  </article>
</BaseLayout>
