---
interface Props {
  href: string;
  label: string;
  external?: boolean;
  iconLeft?: string;
}

const { href, label, external = false, iconLeft } = Astro.props;

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};

/* Phosphor Light – ArrowSquareUpRight (16×16) */
const arrowSquareUpRight = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor"><path d="M208,34H48A14,14,0,0,0,34,48V208a14,14,0,0,0,14,14H208a14,14,0,0,0,14-14V48A14,14,0,0,0,208,34Zm2,174a2,2,0,0,1-2,2H48a2,2,0,0,1-2-2V48a2,2,0,0,1,2-2H208a2,2,0,0,1,2,2ZM166,96v48a6,6,0,0,1-12,0V110.48l-53.76,53.76a6,6,0,0,1-8.48-8.48L145.52,102H112a6,6,0,0,1,0-12h48A6,6,0,0,1,166,96Z"/></svg>`;
---

<a
  href={href}
  class="btn-primary"
  {...externalAttrs}
>
  {iconLeft && <span class="btn-icon" set:html={iconLeft} />}
  {label}
  {external && <span class="btn-icon" set:html={arrowSquareUpRight} />}
</a>

<style>
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    height: 2rem; /* 32px */
    border-radius: 9999px;
    border: none;
    background: var(--color-bg-surface);
    padding: 0 0.75rem;
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1;
    color: var(--color-text-primary);
    transition: background 0.15s ease;
  }

  .btn-primary:hover {
    background: var(--color-bg-surface-hover);
  }

  .btn-icon {
    display: flex;
    align-items: center;
    color: var(--color-text-secondary);
  }
</style>
