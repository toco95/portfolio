---
interface Props {
  activePage?: 'design' | 'photography' | 'achievements';
}

const { activePage = 'design' } = Astro.props;
---

<!-- Top-left: Name + dropdown -->
<div class="chrome chrome-name-wrapper" style="top: 20px; left: 20px;">
  <button class="chrome-name-pill" id="chrome-name-btn">
    <img src="/profile.webp" alt="Thomas Cochet" width="24" height="24" class="chrome-avatar" />
    <span class="chrome-text-base">Toco</span>
    <svg class="chrome-name-caret" width="16" height="16" viewBox="0 0 256 256" fill="none">
      <path d="M213.66,101.66l-80,80a8,8,0,0,1-11.32,0l-80-80A8,8,0,0,1,53.66,90.34L128,164.69l74.34-74.35a8,8,0,0,1,11.32,11.32Z" fill="currentColor"/>
    </svg>
  </button>
  <div class="chrome-name-menu" id="chrome-name-menu">
    <a href="/about" class="chrome-menu-item">About</a>
    <a href="https://linkedin.com/in/thomascochet" target="_blank" rel="noopener noreferrer" class="chrome-menu-item">LinkedIn <svg class="chrome-menu-icon" width="16" height="16" viewBox="0 0 256 256" fill="none"><path d="M200,64V168a8,8,0,0,1-16,0V83.31L69.66,197.66a8,8,0,0,1-11.32-11.32L172.69,72H88a8,8,0,0,1,0-16H192A8,8,0,0,1,200,64Z" fill="currentColor"/></svg></a>
    <a href="https://github.com/toco95" target="_blank" rel="noopener noreferrer" class="chrome-menu-item">GitHub <svg class="chrome-menu-icon" width="16" height="16" viewBox="0 0 256 256" fill="none"><path d="M200,64V168a8,8,0,0,1-16,0V83.31L69.66,197.66a8,8,0,0,1-11.32-11.32L172.69,72H88a8,8,0,0,1,0-16H192A8,8,0,0,1,200,64Z" fill="currentColor"/></svg></a>
  </div>
</div>

<!-- Top-right: Tab switcher (desktop) -->
<div class="chrome chrome-tabs-wrapper" style="top: 20px; right: 20px;">
  <div class="chrome-tabs">
    <a href="/" class:list={["chrome-tab", activePage === 'design' && "active"]}>Design</a>
    <a href="/photography" class:list={["chrome-tab", activePage === 'photography' && "active"]}>Photography</a>
    <a href="/achievements" class:list={["chrome-tab", activePage === 'achievements' && "active"]}>Achievements</a>
  </div>
</div>

<!-- Top-right: Burger menu (mobile) -->
<div class="chrome chrome-burger-wrapper" style="top: 20px; right: 20px;">
  <button class="chrome-burger" id="chrome-burger" aria-label="Menu">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M14 4H2C1.72 4 1.5 3.78 1.5 3.5S1.72 3 2 3H14C14.28 3 14.5 3.22 14.5 3.5S14.28 4 14 4ZM14.5 8C14.5 7.72 14.28 7.5 14 7.5H2C1.72 7.5 1.5 7.72 1.5 8S1.72 8.5 2 8.5H14C14.28 8.5 14.5 8.28 14.5 8ZM14.5 12.5C14.5 12.22 14.28 12 14 12H2C1.72 12 1.5 12.22 1.5 12.5S1.72 13 2 13H14C14.28 13 14.5 12.78 14.5 12.5Z" fill="currentColor"/>
    </svg>
  </button>
  <div class="chrome-menu" id="chrome-menu">
    <a href="/" class:list={["chrome-menu-item", activePage === 'design' && "active"]}>Design</a>
    <a href="/photography" class:list={["chrome-menu-item", activePage === 'photography' && "active"]}>Photography</a>
    <a href="/achievements" class:list={["chrome-menu-item", activePage === 'achievements' && "active"]}>Achievements</a>
  </div>
</div>

<script>
  function initMenus() {
    // Name dropdown
    const nameBtn = document.getElementById('chrome-name-btn');
    const nameMenu = document.getElementById('chrome-name-menu');

    if (nameBtn && nameMenu) {
      nameBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        nameMenu.classList.toggle('open');
        nameBtn.classList.toggle('open');
        // Close burger menu if open
        document.getElementById('chrome-menu')?.classList.remove('open');
      });
      nameMenu.addEventListener('click', (e) => e.stopPropagation());
    }

    // Burger menu
    const burger = document.getElementById('chrome-burger');
    const burgerMenu = document.getElementById('chrome-menu');

    if (burger && burgerMenu) {
      burger.addEventListener('click', (e) => {
        e.stopPropagation();
        burgerMenu.classList.toggle('open');
        // Close name menu if open
        nameMenu?.classList.remove('open');
        nameBtn?.classList.remove('open');
      });
      burgerMenu.addEventListener('click', (e) => e.stopPropagation());
    }

    // Close all on outside click
    document.addEventListener('click', () => {
      nameMenu?.classList.remove('open');
      nameBtn?.classList.remove('open');
      burgerMenu?.classList.remove('open');
    });
  }

  document.addEventListener('astro:page-load', initMenus);
</script>

<style>
  /* ─── Shared text style ─── */

  .chrome-text-base {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    letter-spacing: 0;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .chrome-avatar {
    border-radius: var(--radius-pill);
    display: block;
  }

  /* ─── Name pill ─── */

  .chrome-name-wrapper {
    position: fixed;
  }

  .chrome-name-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 40px;
    padding: 6px 12px 6px 8px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
  }

  .chrome-name-caret {
    color: var(--color-text-tertiary);
    transition: transform 0.2s ease;
  }

  .chrome-name-pill.open .chrome-name-caret {
    transform: rotate(180deg);
  }

  .chrome-name-menu {
    position: absolute;
    top: 48px;
    left: 0;
    display: flex;
    flex-direction: column;
    padding: 4px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .chrome-name-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* ─── Tab switcher (desktop) ─── */

  .chrome-tabs {
    display: flex;
    align-items: center;
    padding: 4px;
    background: var(--color-bg-active);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    height: 40px;
    box-sizing: border-box;
    box-shadow: var(--shadow-md);
  }

  .chrome-tab {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    letter-spacing: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 10px;
    border-radius: var(--radius-pill);
    color: var(--color-text-tertiary);
    white-space: nowrap;
    transition: color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }

  .chrome-tab.active {
    color: var(--color-text-primary);
    background: var(--color-bg-element);
    box-shadow: var(--shadow-sm);
  }

  .chrome-tab:not(.active):hover {
    color: var(--color-text-secondary);
  }

  /* ─── Burger menu (mobile) ─── */

  .chrome-burger-wrapper {
    display: none;
  }

  .chrome-burger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    cursor: pointer;
    color: var(--color-text-primary);
  }

  .chrome-menu {
    position: absolute;
    top: 48px;
    right: 0;
    display: flex;
    flex-direction: column;
    padding: 4px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .chrome-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .chrome-menu-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    color: var(--color-text-tertiary);
    text-decoration: none;
    padding: 8px 16px;
    border-radius: var(--radius-md);
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .chrome-menu-icon {
    flex-shrink: 0;
    color: currentColor;
    opacity: 0.5;
  }

  .chrome-menu-item.active {
    color: var(--color-text-primary);
  }

  .chrome-menu-item:hover {
    background: var(--color-bg-hover);
    color: var(--color-text-primary);
  }

  /* ─── Responsive ─── */

  @media (max-width: 768px) {
    .chrome-tabs-wrapper { display: none; }
    .chrome-burger-wrapper { display: block; }
  }

</style>
