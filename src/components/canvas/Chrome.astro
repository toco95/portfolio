---
interface Props {
  activePage?: 'about' | 'design' | 'photography' | 'achievements';
}

const { activePage = 'design' } = Astro.props;
---

<!-- Top-left: Name pill + Palette button -->
<div class="chrome chrome-topleft" style="top: 20px; left: 20px;">
  <div class="chrome-pill-wrapper">
    <button class="chrome-name-pill" id="chrome-name-btn">
      <img src="/profile.webp" alt="Thomas Cochet" width="24" height="24" class="chrome-avatar" />
      <span class="chrome-text-base">Toco</span>
      <svg class="chrome-name-caret" width="16" height="16" viewBox="0 0 256 256" fill="none">
        <path d="M213.66,101.66l-80,80a8,8,0,0,1-11.32,0l-80-80A8,8,0,0,1,53.66,90.34L128,164.69l74.34-74.35a8,8,0,0,1,11.32,11.32Z" fill="currentColor"/>
      </svg>
    </button>
    <div class="chrome-name-menu" id="chrome-name-menu">
      <a href="/achievements" class="chrome-menu-item">Achievements</a>
      <a href="https://linkedin.com/in/thomascochet" target="_blank" rel="noopener noreferrer" class="chrome-menu-item">LinkedIn <svg class="chrome-menu-icon" width="16" height="16" viewBox="0 0 256 256" fill="none"><path d="M200,64V168a8,8,0,0,1-16,0V83.31L69.66,197.66a8,8,0,0,1-11.32-11.32L172.69,72H88a8,8,0,0,1,0-16H192A8,8,0,0,1,200,64Z" fill="currentColor"/></svg></a>
      <a href="https://github.com/toco95" target="_blank" rel="noopener noreferrer" class="chrome-menu-item">GitHub <svg class="chrome-menu-icon" width="16" height="16" viewBox="0 0 256 256" fill="none"><path d="M200,64V168a8,8,0,0,1-16,0V83.31L69.66,197.66a8,8,0,0,1-11.32-11.32L172.69,72H88a8,8,0,0,1,0-16H192A8,8,0,0,1,200,64Z" fill="currentColor"/></svg></a>
    </div>
  </div>

  <div class="chrome-pill-wrapper">
    <button class="chrome-palette-btn" id="chrome-palette-btn" aria-label="Theme">
      <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor">
        <path d="M200.77,53.89A103.27,103.27,0,0,0,128,24h-1.07A104,104,0,0,0,24,128c0,43,26.58,79.06,69.36,94.17A32,32,0,0,0,136,192a16,16,0,0,1,16-16h46.21a31.81,31.81,0,0,0,31.2-24.88,104.43,104.43,0,0,0,2.59-24A103.28,103.28,0,0,0,200.77,53.89Zm13,93.71A15.89,15.89,0,0,1,198.21,160H152a32,32,0,0,0-32,32,16,16,0,0,1-21.31,15.07C62.49,194.3,40,164,40,128a88,88,0,0,1,87.09-88h.9a88.35,88.35,0,0,1,88,87.25A88.86,88.86,0,0,1,213.81,147.6ZM140,76a12,12,0,1,1-12-12A12,12,0,0,1,140,76ZM96,100A12,12,0,1,1,84,88,12,12,0,0,1,96,100Zm0,56a12,12,0,1,1-12-12A12,12,0,0,1,96,156Zm88-56a12,12,0,1,1-12-12A12,12,0,0,1,184,100Z"/>
      </svg>
    </button>
    <div class="chrome-palette-menu" id="chrome-palette-menu">
      <p class="palette-title">Theme</p>
      <button class="palette-option" data-theme-value="noon">
        <span class="palette-preview" style="background: linear-gradient(135deg, #F5F5F5 50%, #FFFFFF 50%);"></span>
        <span class="palette-name">Noon</span>
        <svg class="palette-check" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>
      </button>
      <button class="palette-option" data-theme-value="sand">
        <span class="palette-preview" style="background: linear-gradient(135deg, #F4EFE7 50%, #FBF8F3 50%);"></span>
        <span class="palette-name">Sand</span>
        <svg class="palette-check" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>
      </button>
      <button class="palette-option" data-theme-value="dusk">
        <span class="palette-preview" style="background: linear-gradient(135deg, #1C1917 50%, #2A2622 50%);"></span>
        <span class="palette-name">Dusk</span>
        <svg class="palette-check" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>
      </button>
      <button class="palette-option" data-theme-value="midnight">
        <span class="palette-preview" style="background: linear-gradient(135deg, #131313 50%, #1F1F1F 50%);"></span>
        <span class="palette-name">Midnight</span>
        <svg class="palette-check" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- Top-right: Tab switcher (desktop) -->
<div class="chrome chrome-tabs-wrapper" style="top: 20px; right: 20px;">
  <div class="chrome-tabs">
    <a href="/" class:list={["chrome-tab", activePage === 'about' && "active"]}>About</a>
    <a href="/design" class:list={["chrome-tab", activePage === 'design' && "active"]}>Design</a>
    <a href="/photography" class:list={["chrome-tab", activePage === 'photography' && "active"]}>Photography</a>
  </div>
</div>

<!-- Top-right: Burger menu (mobile) -->
<div class="chrome chrome-burger-wrapper" style="top: 20px; right: 20px;">
  <button class="chrome-burger" id="chrome-burger" aria-label="Menu">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M14 4H2C1.72 4 1.5 3.78 1.5 3.5S1.72 3 2 3H14C14.28 3 14.5 3.22 14.5 3.5S14.28 4 14 4ZM14.5 8C14.5 7.72 14.28 7.5 14 7.5H2C1.72 7.5 1.5 7.72 1.5 8S1.72 8.5 2 8.5H14C14.28 8.5 14.5 8.28 14.5 8ZM14.5 12.5C14.5 12.22 14.28 12 14 12H2C1.72 12 1.5 12.22 1.5 12.5S1.72 13 2 13H14C14.28 13 14.5 12.78 14.5 12.5Z" fill="currentColor"/>
    </svg>
  </button>
  <div class="chrome-menu" id="chrome-menu">
    <a href="/" class:list={["chrome-menu-item", activePage === 'about' && "active"]}>About</a>
    <a href="/design" class:list={["chrome-menu-item", activePage === 'design' && "active"]}>Design</a>
    <a href="/photography" class:list={["chrome-menu-item", activePage === 'photography' && "active"]}>Photography</a>
  </div>
</div>

<script>
  function initMenus() {
    // Name dropdown
    const nameBtn = document.getElementById('chrome-name-btn');
    const nameMenu = document.getElementById('chrome-name-menu');

    // Palette dropdown
    const paletteBtn = document.getElementById('chrome-palette-btn');
    const paletteMenu = document.getElementById('chrome-palette-menu');

    // Burger menu
    const burger = document.getElementById('chrome-burger');
    const burgerMenu = document.getElementById('chrome-menu');

    function closeAll() {
      nameMenu?.classList.remove('open');
      nameBtn?.classList.remove('open');
      paletteMenu?.classList.remove('open');
      burgerMenu?.classList.remove('open');
    }

    if (nameBtn && nameMenu) {
      nameBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = nameMenu.classList.contains('open');
        closeAll();
        if (!wasOpen) {
          nameMenu.classList.add('open');
          nameBtn.classList.add('open');
        }
      });
      nameMenu.addEventListener('click', (e) => e.stopPropagation());
    }

    if (paletteBtn && paletteMenu) {
      paletteBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = paletteMenu.classList.contains('open');
        closeAll();
        if (!wasOpen) paletteMenu.classList.add('open');
      });
      paletteMenu.addEventListener('click', (e) => e.stopPropagation());

      // Theme selection
      paletteMenu.querySelectorAll<HTMLElement>('.palette-option').forEach((opt) => {
        opt.addEventListener('click', () => {
          const theme = opt.dataset.themeValue;
          if (!theme) return;
          document.documentElement.dataset.theme = theme;
          try { localStorage.setItem('theme', theme); } catch {}
          markActiveTheme(theme);
        });
      });

      markActiveTheme(document.documentElement.dataset.theme || 'noon');
    }

    if (burger && burgerMenu) {
      burger.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = burgerMenu.classList.contains('open');
        closeAll();
        if (!wasOpen) burgerMenu.classList.add('open');
      });
      burgerMenu.addEventListener('click', (e) => e.stopPropagation());
    }

    document.addEventListener('click', closeAll);
  }

  function markActiveTheme(theme: string) {
    document.querySelectorAll<HTMLElement>('.palette-option').forEach((opt) => {
      opt.classList.toggle('active', opt.dataset.themeValue === theme);
    });
  }

  document.addEventListener('astro:page-load', initMenus);
</script>

<style>
  /* ─── Shared text style ─── */

  .chrome-text-base {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    letter-spacing: 0;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .chrome-avatar {
    border-radius: var(--radius-pill);
    display: block;
  }

  /* ─── Top-left pill cluster ─── */

  .chrome-topleft {
    position: fixed;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .chrome-pill-wrapper {
    position: relative;
  }

  /* ─── Name pill ─── */

  .chrome-name-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 40px;
    padding: 6px 12px 6px 8px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
  }

  .chrome-name-caret {
    color: var(--color-text-tertiary);
    transition: transform 0.2s ease;
  }

  .chrome-name-pill.open .chrome-name-caret {
    transform: rotate(180deg);
  }

  .chrome-name-menu {
    position: absolute;
    top: 48px;
    left: 0;
    display: flex;
    flex-direction: column;
    padding: 4px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .chrome-name-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* ─── Tab switcher (desktop) ─── */

  .chrome-tabs {
    display: flex;
    align-items: center;
    padding: 4px;
    background: var(--color-bg-active);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    height: 40px;
    box-sizing: border-box;
    box-shadow: var(--shadow-md);
  }

  .chrome-tab {
    position: relative;
    isolation: isolate;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    letter-spacing: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 10px;
    border-radius: var(--radius-pill);
    color: var(--color-text-secondary);
    white-space: nowrap;
    transition: color 0.2s ease;
    text-decoration: none;
  }

  /* Active pill background lives on a pseudo-element so only it morphs
     between tabs (the labels stay put). */
  .chrome-tab.active {
    color: var(--color-text-primary);
  }

  .chrome-tab.active::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--color-bg-element);
    box-shadow: var(--shadow-sm);
    z-index: -1;
    view-transition-name: active-tab-bg;
  }

  ::view-transition-old(active-tab-bg),
  ::view-transition-new(active-tab-bg) {
    animation-duration: 0.35s;
    animation-timing-function: cubic-bezier(0.32, 0.72, 0, 1);
  }

  .chrome-tab:not(.active):hover {
    color: var(--color-text-secondary);
  }

  /* ─── Palette pill (theme switcher) ─── */

  .chrome-palette-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    cursor: pointer;
    color: var(--color-text-primary);
    font-family: inherit;
    padding: 0;
  }

  .chrome-palette-menu {
    position: absolute;
    top: 48px;
    left: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px;
    width: 200px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 100;
  }

  .chrome-palette-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .palette-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    margin: 0;
    padding: 6px 10px 8px;
  }

  .palette-option {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 10px;
    background: none;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    width: 100%;
    color: var(--color-text-primary);
    transition: background 0.15s ease;
  }

  .palette-option:hover {
    background: var(--color-bg-hover);
  }

  .palette-preview {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 0.5px solid var(--color-border-primary);
    flex-shrink: 0;
  }

  .palette-name {
    flex: 1;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1.25;
  }

  .palette-check {
    color: var(--color-text-secondary);
    opacity: 0;
    flex-shrink: 0;
  }

  .palette-option.active .palette-check {
    opacity: 1;
  }

  /* ─── Burger menu (mobile) ─── */

  .chrome-burger-wrapper {
    display: none;
  }

  .chrome-burger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    cursor: pointer;
    color: var(--color-text-primary);
  }

  .chrome-menu {
    position: absolute;
    top: 48px;
    right: 0;
    display: flex;
    flex-direction: column;
    padding: 4px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .chrome-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .chrome-menu-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 8px 16px;
    border-radius: var(--radius-md);
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .chrome-menu-icon {
    flex-shrink: 0;
    color: currentColor;
    opacity: 0.5;
  }

  .chrome-menu-item.active {
    color: var(--color-text-primary);
  }

  .chrome-menu-item:hover {
    background: var(--color-bg-hover);
    color: var(--color-text-primary);
  }

  /* ─── Responsive ─── */

  @media (max-width: 768px) {
    .chrome-tabs-wrapper { display: none; }
    .chrome-burger-wrapper { display: block; }
  }

</style>
