---
import Icon from '../Icon.astro';
import { links } from '../../data/links';

interface Props {
  activePage?: 'about' | 'design' | 'photography';
  animateIntro?: boolean;
}

const { activePage = 'design', animateIntro = false } = Astro.props;

const dropdownItems = [
  { label: 'Book a call', icon: '/images/icons/cal.svg',       href: links.scheduling.cal },
  { label: 'Hyperline',   icon: '/images/icons/hyperline.svg', href: links.work.hyperline },
  { label: 'Recccords',   icon: '/images/icons/recccords.svg', href: links.work.recccords },
  { label: 'LinkedIn',    icon: '/images/icons/linkedin.svg',  href: links.social.linkedin },
  { label: 'GitHub',      icon: '/images/icons/github.svg',    href: links.social.github },
];
---

<!-- Top-left: Name pill + Palette button -->
<div class:list={["chrome", "chrome-topleft", animateIntro && "intro"]} style="top: var(--space-5); left: var(--space-5);">
  <div class="chrome-pill-wrapper">
    <button class="chrome-name-pill" id="chrome-name-btn">
      <img src="/images/icons/profile.webp" alt="Thomas Cochet" width="24" height="24" loading="eager" decoding="async" class="chrome-avatar" />
      <span class="chrome-text-base">Toco</span>
      <Icon name="caret-down" size={16} class="chrome-name-caret" />
    </button>
    <div class="chrome-name-menu" id="chrome-name-menu">
      {dropdownItems.map((item) => (
        <a href={item.href} target="_blank" rel="noopener noreferrer" class="chrome-menu-item">
          <span class="chrome-menu-label">
            <img src={item.icon} alt="" width="20" height="20" loading="lazy" decoding="async" class="chrome-menu-brand" />
            {item.label}
          </span>
          <Icon name="arrow-up-right" size={16} class="chrome-menu-icon" />
        </a>
      ))}
    </div>
  </div>

  <div class="chrome-pill-wrapper">
    <button class="chrome-palette-btn" id="chrome-palette-btn" aria-label="Theme">
      <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor">
        <path d="M200.77,53.89A103.27,103.27,0,0,0,128,24h-1.07A104,104,0,0,0,24,128c0,43,26.58,79.06,69.36,94.17A32,32,0,0,0,136,192a16,16,0,0,1,16-16h46.21a31.81,31.81,0,0,0,31.2-24.88,104.43,104.43,0,0,0,2.59-24A103.28,103.28,0,0,0,200.77,53.89Zm13,93.71A15.89,15.89,0,0,1,198.21,160H152a32,32,0,0,0-32,32,16,16,0,0,1-21.31,15.07C62.49,194.3,40,164,40,128a88,88,0,0,1,87.09-88h.9a88.35,88.35,0,0,1,88,87.25A88.86,88.86,0,0,1,213.81,147.6ZM140,76a12,12,0,1,1-12-12A12,12,0,0,1,140,76ZM96,100A12,12,0,1,1,84,88,12,12,0,0,1,96,100Zm0,56a12,12,0,1,1-12-12A12,12,0,0,1,96,156Zm88-56a12,12,0,1,1-12-12A12,12,0,0,1,184,100Z"/>
      </svg>
    </button>
    <div class="chrome-palette-menu" id="chrome-palette-menu">
      <p class="palette-title">Theme</p>
      <button class="palette-option" data-theme-value="noon">
        <span class="palette-preview" style="background: linear-gradient(135deg, #F5F5F5 50%, #FFFFFF 50%);"></span>
        <span class="palette-name">Noon</span>
        <svg class="palette-check" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>
      </button>
      <button class="palette-option" data-theme-value="sand">
        <span class="palette-preview" style="background: linear-gradient(135deg, #F4EFE7 50%, #FBF8F3 50%);"></span>
        <span class="palette-name">Sand</span>
        <svg class="palette-check" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>
      </button>
      <button class="palette-option" data-theme-value="dusk">
        <span class="palette-preview" style="background: linear-gradient(135deg, #1C1917 50%, #2A2622 50%);"></span>
        <span class="palette-name">Dusk</span>
        <svg class="palette-check" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>
      </button>
      <button class="palette-option" data-theme-value="midnight">
        <span class="palette-preview" style="background: linear-gradient(135deg, #131313 50%, #1F1F1F 50%);"></span>
        <span class="palette-name">Midnight</span>
        <svg class="palette-check" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- Top-right: Tab switcher (desktop) -->
<div class:list={["chrome", "chrome-tabs-wrapper", animateIntro && "intro"]} style="top: var(--space-5); right: var(--space-5);" transition:persist="chrome-tabs">
  <div class="chrome-tabs">
    <div class="chrome-tabs-slider" id="chrome-tabs-slider"></div>
    <a href="/" data-page="about" class:list={["chrome-tab", activePage === 'about' && "active"]}>About</a>
    <a href="/design" data-page="design" class:list={["chrome-tab", activePage === 'design' && "active"]}>Design</a>
    <a href="/photography" data-page="photography" class:list={["chrome-tab", activePage === 'photography' && "active"]}>Photography</a>
  </div>
</div>

<!-- Top-right: Burger menu (mobile) -->
<div class:list={["chrome", "chrome-burger-wrapper", animateIntro && "intro"]} style="top: var(--space-5); right: var(--space-5);">
  <button class="chrome-burger" id="chrome-burger" aria-label="Menu">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M14 4H2C1.72 4 1.5 3.78 1.5 3.5S1.72 3 2 3H14C14.28 3 14.5 3.22 14.5 3.5S14.28 4 14 4ZM14.5 8C14.5 7.72 14.28 7.5 14 7.5H2C1.72 7.5 1.5 7.72 1.5 8S1.72 8.5 2 8.5H14C14.28 8.5 14.5 8.28 14.5 8ZM14.5 12.5C14.5 12.22 14.28 12 14 12H2C1.72 12 1.5 12.22 1.5 12.5S1.72 13 2 13H14C14.28 13 14.5 12.78 14.5 12.5Z" fill="currentColor"/>
    </svg>
  </button>
  <div class="chrome-menu" id="chrome-menu">
    <a href="/" class:list={["chrome-menu-item", activePage === 'about' && "active"]}>About</a>
    <a href="/design" class:list={["chrome-menu-item", activePage === 'design' && "active"]}>Design</a>
    <a href="/photography" class:list={["chrome-menu-item", activePage === 'photography' && "active"]}>Photography</a>
  </div>
</div>

<script>
  function initMenus() {
    // Name dropdown
    const nameBtn = document.getElementById('chrome-name-btn');
    const nameMenu = document.getElementById('chrome-name-menu');

    // Palette dropdown
    const paletteBtn = document.getElementById('chrome-palette-btn');
    const paletteMenu = document.getElementById('chrome-palette-menu');

    // Burger menu
    const burger = document.getElementById('chrome-burger');
    const burgerMenu = document.getElementById('chrome-menu');

    function closeAll() {
      nameMenu?.classList.remove('open');
      nameBtn?.classList.remove('open');
      paletteMenu?.classList.remove('open');
      burgerMenu?.classList.remove('open');
    }

    if (nameBtn && nameMenu) {
      nameBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = nameMenu.classList.contains('open');
        closeAll();
        if (!wasOpen) {
          nameMenu.classList.add('open');
          nameBtn.classList.add('open');
        }
      });
      nameMenu.addEventListener('click', (e) => e.stopPropagation());
    }

    if (paletteBtn && paletteMenu) {
      paletteBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = paletteMenu.classList.contains('open');
        closeAll();
        if (!wasOpen) paletteMenu.classList.add('open');
      });
      paletteMenu.addEventListener('click', (e) => e.stopPropagation());

      // Theme selection
      paletteMenu.querySelectorAll<HTMLElement>('.palette-option').forEach((opt) => {
        opt.addEventListener('click', () => {
          const theme = opt.dataset.themeValue;
          if (!theme) return;
          document.documentElement.dataset.theme = theme;
          try { localStorage.setItem('theme', theme); } catch {}
          markActiveTheme(theme);
        });
      });

      markActiveTheme(document.documentElement.dataset.theme || 'noon');
    }

    if (burger && burgerMenu) {
      burger.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = burgerMenu.classList.contains('open');
        closeAll();
        if (!wasOpen) burgerMenu.classList.add('open');
      });
      burgerMenu.addEventListener('click', (e) => e.stopPropagation());
    }

    document.addEventListener('click', closeAll);
  }

  function markActiveTheme(theme: string) {
    document.querySelectorAll<HTMLElement>('.palette-option').forEach((opt) => {
      opt.classList.toggle('active', opt.dataset.themeValue === theme);
    });
  }

  function pathToPage(): string | null {
    const p = window.location.pathname;
    if (p === '/' || p === '/index.html') return 'about';
    if (p.startsWith('/design')) return 'design';
    if (p.startsWith('/photography')) return 'photography';
    return null;
  }

  function positionTabSlider() {
    const tabs = document.querySelector<HTMLElement>('.chrome-tabs');
    const slider = document.getElementById('chrome-tabs-slider');
    if (!tabs || !slider) return;
    const page = pathToPage();
    tabs.querySelectorAll<HTMLElement>('.chrome-tab').forEach((t) => {
      t.classList.toggle('active', t.dataset.page === page);
    });
    const target = page
      ? tabs.querySelector<HTMLElement>(`.chrome-tab[data-page="${page}"]`)
      : null;
    if (!target) {
      slider.style.opacity = '0';
      return;
    }
    slider.style.opacity = '1';
    slider.style.transform = `translate(${target.offsetLeft}px, ${target.offsetTop}px)`;
    slider.style.width = `${target.offsetWidth}px`;
    slider.style.height = `${target.offsetHeight}px`;
    if (!slider.classList.contains('animated')) {
      requestAnimationFrame(() => slider.classList.add('animated'));
    }
  }

  // Re-measure whenever the chrome-tabs layout shifts (font load, viewport
  // resize, scrollbar toggle on route swap, etc). Without this, the slider
  // can keep a stale width after navigating away and back.
  function observeTabsLayout() {
    const tabs = document.querySelector<HTMLElement>('.chrome-tabs');
    if (!tabs) return;
    const w = window as any;
    if (w.__chromeTabsObserved) return;
    w.__chromeTabsObserved = true;

    if (typeof ResizeObserver !== 'undefined') {
      const ro = new ResizeObserver(() => positionTabSlider());
      tabs.querySelectorAll<HTMLElement>('.chrome-tab').forEach((t) => ro.observe(t));
      ro.observe(tabs);
    }

    window.addEventListener('resize', positionTabSlider);

    // Re-measure once webfonts have loaded, in case the first measurement
    // happened with the fallback font.
    if ((document as any).fonts?.ready) {
      (document as any).fonts.ready.then(() => positionTabSlider());
    }
  }

  // After an Astro view-transition swap, the persisted chrome-tabs-wrapper can
  // be left holding stale layout dimensions from the snapshotted version of
  // the previous page (the same state that a manual window resize clears).
  // Forcing a display toggle replays the layout calc and snaps it back.
  function refreshChromeLayout() {
    const wrapper = document.querySelector<HTMLElement>('.chrome-tabs-wrapper');
    if (!wrapper) return;
    const prevDisplay = wrapper.style.display;
    wrapper.style.display = 'none';
    // Read a layout property to force the engine to commit the hide.
    void wrapper.offsetHeight;
    wrapper.style.display = prevDisplay;
    requestAnimationFrame(() => positionTabSlider());
  }

  function pruneTabsIntro() {
    const wrapper = document.querySelector<HTMLElement>('.chrome-tabs-wrapper');
    if (!wrapper) return;
    if (wrapper.dataset.introDone) {
      wrapper.classList.remove('intro');
      return;
    }
    if (!wrapper.classList.contains('intro')) return;
    if (wrapper.dataset.introListenerAttached) return;
    wrapper.dataset.introListenerAttached = '1';
    wrapper.addEventListener('animationend', (e) => {
      if ((e as AnimationEvent).animationName === 'chrome-fade-up') {
        wrapper.dataset.introDone = '1';
        wrapper.classList.remove('intro');
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    initMenus();
    positionTabSlider();
    observeTabsLayout();
    pruneTabsIntro();
  });

  // Refresh on swap to drop any stale layout the persisted wrapper kept from
  // the view-transition snapshot.
  document.addEventListener('astro:after-swap', refreshChromeLayout);
</script>

<style>
  /* ─── Shared text style ─── */

  .chrome-text-base {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    letter-spacing: 0;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .chrome-avatar {
    border-radius: var(--radius-pill);
    display: block;
  }

  /* ─── Top-left pill cluster ─── */

  .chrome-topleft {
    position: fixed;
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .chrome-pill-wrapper {
    position: relative;
  }

  /* ─── Name pill ─── */

  .chrome-name-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 40px;
    padding: 6px var(--space-3) 6px var(--space-2);
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
  }

  /* :global() so the rule reaches the SVG inside the Icon component, which
     doesn't carry this file's astro-cid scope attribute. */
  :global(.chrome-name-caret) {
    color: var(--color-text-tertiary);
    transition: transform 0.2s ease;
  }

  .chrome-name-pill:hover :global(.chrome-name-caret),
  .chrome-name-pill.open :global(.chrome-name-caret) {
    transform: rotate(180deg);
  }

  .chrome-name-menu {
    position: absolute;
    top: var(--space-12);
    left: 0;
    display: flex;
    flex-direction: column;
    padding: var(--space-1);
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .chrome-name-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* ─── Tab switcher (desktop) ─── */

  .chrome-tabs {
    position: relative;
    display: flex;
    align-items: center;
    padding: var(--space-1);
    background: var(--color-bg-active);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    height: 40px;
    box-sizing: border-box;
    box-shadow: var(--shadow-md);
  }

  /* Single shared pill that translates + resizes between tabs. */
  .chrome-tabs-slider {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    background: var(--color-bg-element);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    pointer-events: none;
    opacity: 0;
  }

  .chrome-tabs-slider.animated {
    transition:
      transform 0.35s cubic-bezier(0.32, 0.72, 0, 1),
      width 0.35s cubic-bezier(0.32, 0.72, 0, 1),
      height 0.35s cubic-bezier(0.32, 0.72, 0, 1),
      opacity 0.2s ease;
  }

  .chrome-tab {
    position: relative;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    letter-spacing: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 10px;
    border-radius: var(--radius-pill);
    color: var(--color-text-secondary);
    white-space: nowrap;
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .chrome-tab.active {
    color: var(--color-text-primary);
  }

  .chrome-tab:not(.active):hover {
    color: var(--color-text-secondary);
  }

  /* ─── Palette pill (theme switcher) ─── */

  .chrome-palette-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    cursor: pointer;
    color: var(--color-text-primary);
    font-family: inherit;
    padding: 0;
  }

  .chrome-palette-menu {
    position: absolute;
    top: var(--space-12);
    left: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px;
    width: 200px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 100;
  }

  .chrome-palette-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .palette-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    margin: 0;
    padding: 6px 10px var(--space-2);
  }

  .palette-option {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) 10px;
    background: none;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    width: 100%;
    color: var(--color-text-primary);
    transition: background 0.15s ease;
  }

  .palette-option:hover {
    background: var(--color-bg-hover);
  }

  .palette-preview {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 0.5px solid var(--color-border-primary);
    flex-shrink: 0;
  }

  .palette-name {
    flex: 1;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1.25;
  }

  .palette-check {
    color: var(--color-text-secondary);
    opacity: 0;
    flex-shrink: 0;
  }

  .palette-option.active .palette-check {
    opacity: 1;
  }

  /* ─── Burger menu (mobile) ─── */

  .chrome-burger-wrapper {
    display: none;
  }

  .chrome-burger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    cursor: pointer;
    color: var(--color-text-primary);
  }

  .chrome-menu {
    position: absolute;
    top: var(--space-12);
    right: 0;
    display: flex;
    flex-direction: column;
    padding: var(--space-1);
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .chrome-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .chrome-menu-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--text-base--line-height);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .chrome-menu-icon {
    flex-shrink: 0;
    color: currentColor;
    opacity: 0.5;
  }

  .chrome-menu-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .chrome-menu-brand {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    flex-shrink: 0;
    display: block;
  }

  .chrome-menu-item.active {
    color: var(--color-text-primary);
  }

  .chrome-menu-item:hover {
    background: var(--color-bg-hover);
    color: var(--color-text-primary);
  }

  /* ─── Responsive ─── */

  @media (max-width: 768px) {
    .chrome-tabs-wrapper { display: none; }
    .chrome-burger-wrapper { display: block; }
  }

  /* ─── Intro animation (only on /about) ─── */

  @keyframes chrome-fade-up {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  html.intro-active .chrome-topleft.intro .chrome-pill-wrapper:nth-child(1) {
    animation: chrome-fade-up 700ms cubic-bezier(0.16, 1, 0.3, 1) 800ms backwards;
  }
  html.intro-active .chrome-topleft.intro .chrome-pill-wrapper:nth-child(2) {
    animation: chrome-fade-up 700ms cubic-bezier(0.16, 1, 0.3, 1) 880ms backwards;
  }
  html.intro-active .chrome-tabs-wrapper.intro,
  html.intro-active .chrome-burger-wrapper.intro {
    animation: chrome-fade-up 700ms cubic-bezier(0.16, 1, 0.3, 1) 800ms backwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .chrome-topleft.intro .chrome-pill-wrapper,
    .chrome-tabs-wrapper.intro,
