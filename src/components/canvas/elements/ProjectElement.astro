        </svg>
      )}
      {cat.icon === 'stack' && (
        <svg width="16" height="16" viewBox="0 0 16.26 17.5" fill="none" style="overflow: visible;">
          <path d="M16.1648 12.1874C16.2474 12.3307 16.2698 12.5008 16.2272 12.6606C16.1846 12.8203 16.0804 12.9567 15.9375 13.0398L8.4375 17.4148C8.34193 17.4705 8.23329 17.4999 8.12266 17.4999C8.01203 17.4999 7.90338 17.4705 7.80781 17.4148L0.307813 13.0398C0.166948 12.9551 0.0650922 12.8184 0.0242969 12.6592C-0.0164984 12.5 0.00705024 12.3312 0.0898442 12.1892C0.172638 12.0472 0.308014 11.9436 0.466663 11.9007C0.625312 11.8578 0.794465 11.8792 0.9375 11.9601L8.125 16.1515L15.3125 11.9601C15.4558 11.8775 15.6259 11.8551 15.7856 11.8977C15.9454 11.9403 16.0817 12.0445 16.1648 12.1874ZM15.3125 8.21009L8.125 12.4015L0.9375 8.21009C0.795191 8.13924 0.63123 8.12528 0.478988 8.17105C0.326747 8.21682 0.197669 8.31888 0.118026 8.45647C0.0383825 8.59405 0.0141606 8.75681 0.0502898 8.91162C0.086419 9.06644 0.180184 9.20166 0.3125 9.28978L7.8125 13.6648C7.90807 13.7205 8.01671 13.7499 8.12734 13.7499C8.23797 13.7499 8.34662 13.7205 8.44219 13.6648L15.9422 9.28978C16.0142 9.24903 16.0774 9.19437 16.1282 9.12898C16.1789 9.06359 16.2162 8.98878 16.2378 8.90888C16.2594 8.82898 16.2649 8.74559 16.254 8.66354C16.2431 8.5815 16.216 8.50243 16.1743 8.43094C16.1326 8.35944 16.0771 8.29694 16.0111 8.24706C15.945 8.19718 15.8697 8.16092 15.7896 8.14037C15.7094 8.11983 15.6259 8.11541 15.544 8.12738C15.4621 8.13935 15.3834 8.16746 15.3125 8.21009ZM0 4.99994C0.000249251 4.89047 0.0292463 4.78299 0.084089 4.68824C0.138932 4.5935 0.217697 4.51483 0.3125 4.46009L7.8125 0.0850941C7.90807 0.0293645 8.01671 0 8.12734 0C8.23797 0 8.34662 0.0293645 8.44219 0.0850941L15.9422 4.46009C16.0365 4.51514 16.1148 4.59395 16.1692 4.68867C16.2236 4.78339 16.2522 4.89071 16.2522 4.99994C16.2522 5.10917 16.2236 5.21649 16.1692 5.31121C16.1148 5.40593 16.0365 5.48474 15.9422 5.53978L8.44219 9.91478C8.34662 9.97051 8.23797 9.99988 8.12734 9.99988C8.01671 9.99988 7.90807 9.97051 7.8125 9.91478L0.3125 5.53978C0.217697 5.48505 0.138932 5.40637 0.084089 5.31163C0.0292463 5.21689 0.000249251 5.10941 0 4.99994ZM1.86563 4.99994L8.125 8.6515L14.3844 4.99994L8.125 1.34838L1.86563 4.99994Z" fill="white"/>
        </svg>
      )}
    </div>
    <span>{cat.label}</span>
  </div>

  {/* Cover image */}
  <div class="project-cover">
    {cover ? (
      <img src={cover} alt={title} loading="lazy" decoding="async" draggable="false" />
    ) : (
      <div class="project-placeholder">
        <span>{title}</span>
      </div>
    )}

    {/* Click to read more tag */}
    {hasLink && (
      <div class="project-read-tag">
        <span>Click to read more</span>
        <svg width="12" height="12" viewBox="0 0 11 11" fill="none">
          <path d="M11 0.5V3.5C11 3.63261 10.9473 3.75979 10.8536 3.85355C10.7598 3.94732 10.6326 4 10.5 4C10.3674 4 10.2402 3.94732 10.1464 3.85355C10.0527 3.75979 10 3.63261 10 3.5V1.70687L7.35375 4.35375C7.25993 4.44757 7.13268 4.50028 7 4.50028C6.86732 4.50028 6.74007 4.44757 6.64625 4.35375C6.55243 4.25993 6.49972 4.13268 6.49972 4C6.49972 3.86732 6.55243 3.74007 6.64625 3.64625L9.29313 1H7.5C7.36739 1 7.24021 0.947321 7.14645 0.853553C7.05268 0.759785 7 0.632608 7 0.5C7 0.367392 7.05268 0.240215 7.14645 0.146447C7.24021 0.0526785 7.36739 0 7.5 0H10.5C10.6326 0 10.7598 0.0526785 10.8536 0.146447C10.9473 0.240215 11 0.367392 11 0.5ZM3.64625 6.64625L1 9.29313V7.5C1 7.36739 0.947321 7.24021 0.853553 7.14645C0.759785 7.05268 0.632608 7 0.5 7C0.367392 7 0.240215 7.05268 0.146447 7.14645C0.0526785 7.24021 0 7.36739 0 7.5V10.5C0 10.6326 0.0526785 10.7598 0.146447 10.8536C0.240215 10.9473 0.367392 11 0.5 11H3.5C3.63261 11 3.75979 10.9473 3.85355 10.8536C3.94732 10.7598 4 10.6326 4 10.5C4 10.3674 3.94732 10.2402 3.85355 10.1464C3.75979 10.0527 3.63261 10 3.5 10H1.70687L4.35375 7.35375C4.44757 7.25993 4.50028 7.13268 4.50028 7C4.50028 6.86732 4.44757 6.74007 4.35375 6.64625C4.25993 6.55243 4.13268 6.49972 4 6.49972C3.86732 6.49972 3.74007 6.55243 3.64625 6.64625ZM10.5 7C10.3674 7 10.2402 7.05268 10.1464 7.14645C10.0527 7.24021 10 7.36739 10 7.5V9.29313L7.35375 6.64625C7.25993 6.55243 7.13268 6.49972 7 6.49972C6.86732 6.49972 6.74007 6.55243 6.64625 6.64625C6.55243 6.74007 6.49972 6.86732 6.49972 7C6.49972 7.13268 6.55243 7.25993 6.64625 7.35375L9.29313 10H7.5C7.36739 10 7.24021 10.0527 7.14645 10.1464C7.05268 10.2402 7 10.3674 7 10.5C7 10.6326 7.05268 10.7598 7.14645 10.8536C7.24021 10.9473 7.36739 11 7.5 11H10.5C10.6326 11 10.7598 10.9473 10.8536 10.8536C10.9473 10.7598 11 10.6326 11 10.5V7.5C11 7.36739 10.9473 7.24021 10.8536 7.14645C10.7598 7.05268 10.6326 7 10.5 7ZM1.70687 1H3.5C3.63261 1 3.75979 0.947321 3.85355 0.853553C3.94732 0.759785 4 0.632608 4 0.5C4 0.367392 3.94732 0.240215 3.85355 0.146447C3.75979 0.0526785 3.63261 0 3.5 0H0.5C0.367392 0 0.240215 0.0526785 0.146447 0.146447C0.0526785 0.240215 0 0.367392 0 0.5V3.5C0 3.63261 0.0526785 3.75979 0.146447 3.85355C0.240215 3.94732 0.367392 4 0.5 4C0.632608 4 0.759785 3.94732 0.853553 3.85355C0.947321 3.75979 1 3.63261 1 3.5V1.70687L3.64625 4.35375C3.74007 4.44757 3.86732 4.50028 4 4.50028C4.13268 4.50028 4.25993 4.44757 4.35375 4.35375C4.44757 4.25993 4.50028 4.13268 4.50028 4C4.50028 3.86732 4.44757 3.74007 4.35375 3.64625L1.70687 1Z" fill="#78716C"/>
        </svg>
      </div>
    )}
  </div>
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    height: 100%;
  }

  .project-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 12px;
    color: white;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0.32px;
    white-space: nowrap;
    align-self: flex-start;
    box-shadow: var(--shadow-md);
  }

  .project-pill-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-cover {
    position: relative;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .project-cover img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
  }

  .project-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
  }

  .project-read-tag {
    position: absolute;
    bottom: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: var(--color-bg-element);
    border-radius: 12px;
    box-shadow: var(--shadow-md);
  }

  .project-read-tag span {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0.32px;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .project-read-tag svg {
    flex-shrink: 0;
  }
</style>
