---
interface Props {
  slug: string;
  imageIndex: number;
  projects: any[];
}

const { slug, imageIndex, projects } = Astro.props;
const project = projects.find(p => p.id === slug);
if (!project) return;

const { title, cover, hasDetailPage, externalUrl, category } = project.data;
const hasLink = hasDetailPage || externalUrl;

const categoryConfig: Record<string, { label: string; bgVar: string; icon: string }> = {
  Product:      { label: 'Product Design', bgVar: 'var(--color-blue-accent)',   icon: 'layout' },
  Design:       { label: 'Product Design', bgVar: 'var(--color-blue-accent)',   icon: 'layout' },
  Branding:     { label: 'Branding',       bgVar: 'var(--color-purple-accent)', icon: 'palette' },
  'Full stack': { label: 'Full stack',     bgVar: 'var(--color-orange-accent)', icon: 'stack' },
  Webdesign:    { label: 'Webdesign',      bgVar: 'var(--color-blue-accent)',   icon: 'layout' },
  Achievement:  { label: 'Achievement',    bgVar: 'var(--color-text-secondary)', icon: 'layout' },
};

const cat = categoryConfig[category] ?? { label: category, bgVar: 'var(--color-text-secondary)', icon: 'layout' };
---

<div
  class="project-card"
  data-project-id={hasDetailPage ? slug : undefined}
  data-external-url={externalUrl || undefined}
>
  {/* Category pill */}
  <div class="project-pill" style={`background: ${cat.bgVar};`}>
    <div class="project-pill-icon">
      {cat.icon === 'layout' && (
        <svg width="16" height="16" viewBox="0 0 16.25 13.75" fill="none" style="overflow: visible;">
          <path d="M15 0H1.25C0.918479 0 0.600537 0.131696 0.366116 0.366116C0.131696 0.600537 0 0.918479 0 1.25V12.5C0 12.8315 0.131696 13.1495 0.366116 13.3839C0.600537 13.6183 0.918479 13.75 1.25 13.75H15C15.3315 13.75 15.6495 13.6183 15.8839 13.3839C16.1183 13.1495 16.25 12.8315 16.25 12.5V1.25C16.25 0.918479 16.1183 0.600537 15.8839 0.366116C15.6495 0.131696 15.3315 0 15 0ZM15 1.25V4.375H1.25V1.25H15ZM1.25 5.625H5.625V12.5H1.25V5.625ZM15 12.5H6.875V5.625H15V12.5Z" fill="white"/>
        </svg>
      )}
      {cat.icon === 'palette' && (
        <svg width="16" height="16" viewBox="0 0 16.25 15.625" fill="none" style="overflow: visible;">
