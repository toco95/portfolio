        </svg>
      </div>
    )}
  </div>
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    height: 100%;
  }

  .project-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: var(--radius-lg);
    color: rgb(var(--color-overlay-light-rgb));
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0;
    white-space: nowrap;
    align-self: flex-start;
    box-shadow: var(--shadow-md);
  }

  .project-pill-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-cover {
    position: relative;
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .interactive .project-cover:hover {
    transform: translateY(-2px) rotate(-0.5deg);
    box-shadow: var(--shadow-lg);
    cursor: pointer;
  }

  .project-cover img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
  }

  .project-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
  }

  .project-read-tag {
    position: absolute;
    bottom: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: var(--color-bg-element);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .project-read-tag span {
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .project-read-tag svg {
    flex-shrink: 0;
    color: var(--color-text-secondary);
  }
</style>
