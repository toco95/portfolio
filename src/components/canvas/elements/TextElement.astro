---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<p class="canvas-text">{text}</p>

<style>
  .canvas-text {
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 480px;
  }
</style>
