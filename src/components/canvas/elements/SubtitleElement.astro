---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<p class="canvas-subtitle">{text}</p>

<style>
  .canvas-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: var(--text-xl--line-height);
    letter-spacing: 0;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 600px;
  }
</style>
