---
interface Props {
  path: string;
}

const { path } = Astro.props;
---

<div class="canvas-image">
  <img src={path} alt="" loading="lazy" decoding="async" draggable="false" />
</div>

<style>
  .canvas-image {
    width: 100%;
    height: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .canvas-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }
</style>
