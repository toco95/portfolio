      <path d="M9.907 4.95505C9.90832 4.74588 9.8635 4.5802 9.92107 4.46627C10.0233 4.26384 10.1877 4.09277 10.3261 3.90859C10.4865 4.09687 10.7649 4.27329 10.7853 4.47567C10.8467 5.08652 10.7989 5.70763 10.8107 6.3244C10.8231 6.97013 10.5284 7.11168 9.90697 6.86824C9.90697 6.25163 9.90697 5.63674 9.907 4.95505Z" fill="currentColor"/>
      <path d="M4.05879 12.875C4.2302 12.8111 4.42054 12.7913 4.66837 12.7767C4.50982 12.8276 4.29376 12.8733 4.05879 12.875Z" fill="currentColor"/>
      <path d="M6.92832 11.9959C7.031 11.9513 7.1415 11.9489 7.30594 11.9592C7.21864 11.994 7.07739 12.016 6.92832 11.9959Z" fill="currentColor"/>
    </svg>
  </button>

  {/* Emoji picker — only visible in emoji mode */}
  <div class="emoji-picker" id="emoji-picker">
    {emojis.length > 0 ? (
      emojis.map((emoji) => (
        <button class="emoji-item" data-emoji-src={emoji.src}>
          <span class="emoji-tooltip">{emoji.name}</span>
          <img src={emoji.src} alt={emoji.name} width="32" height="32" draggable="false" />
        </button>
      ))
    ) : (
      <p class="emoji-empty">Add images to<br/><code>public/images/emoji/</code></p>
    )}
  </div>
</div>

<style>
  .toolbar {
    position: fixed;
    bottom: var(--space-5);
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0;
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    pointer-events: auto;
  }

  .toolbar-mode {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border: none;
    border-radius: var(--radius-pill);
    background: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }

  .toolbar-mode:hover {
    color: var(--color-text-primary);
  }

  .toolbar-mode.active {
    background: var(--color-bg-active);
    color: var(--color-text-primary);
  }

  /* The `.active` class already conveys the selected mode — the browser's
     default focus ring on click adds visual noise on top of it. */
  .toolbar-mode:focus,
  .toolbar-color:focus {
    outline: none;
  }

  .toolbar-divider {
    width: 1px;
    height: 24px;
    background: var(--color-border-secondary);
    border-radius: var(--radius-pill);
    flex-shrink: 0;
    margin: 0 var(--space-2);
  }

  .toolbar-colors {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    max-width: 0;
    margin-left: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-width 0.3s ease, opacity 0.2s ease, margin 0.3s ease;
  }

  .toolbar-colors.visible {
    max-width: 120px;
    margin-left: var(--space-2);
    opacity: 1;
  }

  .toolbar-color {
    width: 16px;
    height: 16px;
    border-radius: var(--radius-pill);
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 0.25;
    transition: opacity 0.12s ease;
    flex-shrink: 0;
  }

  .toolbar-color[data-color-token="primary"] { background: var(--color-text-primary); }
  .toolbar-color[data-color-token="orange"] { background: var(--color-orange-accent); }
  .toolbar-color[data-color-token="blue"] { background: var(--color-blue-accent); }
  .toolbar-color[data-color-token="purple"] { background: var(--color-purple-accent); }

  .toolbar-color.active {
    opacity: 1;
  }

  .toolbar-color:hover {
    opacity: 0.6;
  }

  .toolbar-color.active:hover {
    opacity: 1;
  }

  /* ─── Emoji picker ─── */

  .emoji-picker {
    position: absolute;
    bottom: calc(100% + var(--space-3));
    right: -12px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-1);
    padding: var(--space-2);
    max-width: 240px;
    overflow: visible;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .emoji-picker.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .emoji-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: var(--space-1);
    border: none;
    border-radius: var(--radius-md);
    background: none;
    cursor: pointer;
    transition: background 0.12s ease;
  }

  .emoji-item:hover {
    background: var(--color-bg-hover);
  }

  .emoji-item.active {
    background: var(--color-bg-active);
  }

  .emoji-item img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .emoji-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    padding: var(--space-1) var(--space-2);
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-secondary);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    font-size: 11px;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-text-secondary);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 10;
  }

  .emoji-item:hover .emoji-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .emoji-empty {
    grid-column: 1 / -1;
    font-size: 11px;
    color: var(--color-text-tertiary);
    text-align: center;
    padding: var(--space-2);
    margin: 0;
    line-height: 1.4;
  }

  .emoji-empty code {
    font-size: 10px;
    background: var(--color-bg-active);
    padding: 1px var(--space-1);
    border-radius: var(--radius-sm);
  }

  /* ─── Tooltip ─── */

  .tooltip {
    position: absolute;
    bottom: calc(100% + var(--space-3));
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: 6px var(--space-2);
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-secondary);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    font-size: 12px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0.24px;
    color: var(--color-text-secondary);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .toolbar-mode:hover .tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    transition-delay: 0.4s;
  }

  .tooltip kbd {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 15px;
    height: 15px;
    padding: 0 3px;
    background: var(--color-bg-active);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 10px;
    font-weight: 500;
    line-height: 10px;
    letter-spacing: 0.2px;
    color: var(--color-text-secondary);
    text-align: center;
  }

  @media (max-width: 768px) {
    .toolbar { display: none; }
  }
</style>
