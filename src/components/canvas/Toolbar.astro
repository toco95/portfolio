      <path d="M8.88686 0.495999C9.2577 1.29655 8.52371 2.24831 7.48847 2.35623C5.9691 2.51462 4.44723 2.64885 2.9272 2.80115C2.40481 2.8535 1.88632 2.94985 1.36327 2.98916C0.649803 3.04278 0.14808 2.69011 0.0163879 2.08581C-0.0970117 1.56544 0.395364 0.876251 0.960167 0.643171C3.29621 -0.320852 5.74418 0.0981345 8.15205 0.0512598C8.3847 0.0467298 8.62264 0.313724 8.88686 0.495999ZM1.30611 1.51065C1.22767 1.63634 1.14924 1.76202 1.07081 1.88771C1.21166 1.94821 1.35586 2.0666 1.49276 2.0587C1.96384 2.0315 2.43144 1.94983 2.90207 1.90803C3.61168 1.84501 3.61633 1.8474 3.67586 0.97176C2.90875 1.14534 2.16406 1.31385 1.30611 1.51065ZM4.34212 1.20767C4.55365 1.71578 4.96367 1.71118 5.41017 1.62704C5.95976 1.52349 6.51043 1.42547 7.0614 1.32948C7.25693 1.29542 7.45472 1.27433 7.65148 1.24731C7.64255 1.19309 7.63362 1.13886 7.6247 1.08463C6.54081 1.08463 5.45692 1.08463 4.34212 1.20767Z" fill="currentColor"/>
