---
import fs from 'node:fs';
import path from 'node:path';

const emojiDir = path.join(process.cwd(), 'public/images/emoji');
let emojis: { src: string; name: string }[] = [];
try {
  emojis = fs.readdirSync(emojiDir)
    .filter(f => /\.(png|webp|svg|gif|jpg|jpeg)$/i.test(f))
    .filter(f => !f.startsWith('toco-gun'))
    .sort()
    .map(f => ({
      src: `/images/emoji/${f}`,
      name: f.replace(/\.[^.]+$/, ''),
    }));
} catch {}
---

<div class="toolbar">
  {/* Mode buttons */}
  <button class="toolbar-mode active" data-mode="pan">
    <span class="tooltip">Navigate <kbd>V</kbd></span>
    <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor">
      <path d="M188,48a27.75,27.75,0,0,0-12,2.71V44a28,28,0,0,0-54.65-8.6A28,28,0,0,0,80,60v64l-3.82-6.13a28,28,0,0,0-48.6,27.82c16,33.77,28.93,57.72,43.72,72.69C86.24,233.54,103.2,240,128,240a88.1,88.1,0,0,0,88-88V76A28,28,0,0,0,188,48Zm12,104a72.08,72.08,0,0,1-72,72c-20.38,0-33.51-4.88-45.33-16.85C69.44,193.74,57.26,171,41.9,138.58a6.36,6.36,0,0,0-.3-.58,12,12,0,0,1,20.79-12,1.76,1.76,0,0,0,.14.23l18.67,30A8,8,0,0,0,96,152V60a12,12,0,0,1,24,0v60a8,8,0,0,0,16,0V44a12,12,0,0,1,24,0v76a8,8,0,0,0,16,0V76a12,12,0,0,1,24,0Z"/>
    </svg>
  </button>

  <div class="toolbar-divider"></div>

  <button class="toolbar-mode" data-mode="move">
    <span class="tooltip">Move <kbd>H</kbd></span>
    <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor">
      <path d="M90.34,61.66a8,8,0,0,1,0-11.32l32-32a8,8,0,0,1,11.32,0l32,32a8,8,0,0,1-11.32,11.32L136,43.31V96a8,8,0,0,1-16,0V43.31L101.66,61.66A8,8,0,0,1,90.34,61.66Zm64,132.68L136,212.69V160a8,8,0,0,0-16,0v52.69l-18.34-18.35a8,8,0,0,0-11.32,11.32l32,32a8,8,0,0,0,11.32,0l32-32a8,8,0,0,0-11.32-11.32Zm83.32-72-32-32a8,8,0,0,0-11.32,11.32L212.69,120H160a8,8,0,0,0,0,16h52.69l-18.35,18.34a8,8,0,0,0,11.32,11.32l32-32A8,8,0,0,0,237.66,122.34ZM43.31,136H96a8,8,0,0,0,0-16H43.31l18.35-18.34A8,8,0,0,0,50.34,90.34l-32,32a8,8,0,0,0,0,11.32l32,32a8,8,0,0,0,11.32-11.32Z"/>
    </svg>
  </button>

  <div class="toolbar-divider"></div>

  <button class="toolbar-mode" data-mode="draw">
    <span class="tooltip">Draw <kbd>D</kbd></span>
    <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor">
      <path d="M227.31,73.37,182.63,28.68a16,16,0,0,0-22.63,0L36.69,152A15.86,15.86,0,0,0,32,163.31V208a16,16,0,0,0,16,16H92.69A15.86,15.86,0,0,0,104,219.31L227.31,96A16,16,0,0,0,227.31,73.37ZM92.69,208H48V163.31l88-88L180.69,120ZM192,108.68,147.31,64l24-24L216,84.68Z"/>
    </svg>
  </button>

  {/* Color dots — only visible in draw mode */}
  <div class="toolbar-colors" id="toolbar-colors">
    <button class="toolbar-color active" data-color-token="primary" title="Default"></button>
    <button class="toolbar-color" data-color-token="orange" title="Orange"></button>
    <button class="toolbar-color" data-color-token="blue" title="Blue"></button>
    <button class="toolbar-color" data-color-token="purple" title="Purple"></button>
  </div>

  <div class="toolbar-divider"></div>

  <button class="toolbar-mode" data-mode="emoji" id="toolbar-emoji-btn">
    <span class="tooltip">Emoji <kbd>E</kbd></span>
