    </svg>
  </button>

  {/* Color dots — only visible in draw mode */}
  <div class="toolbar-colors" id="toolbar-colors">
    <button class="toolbar-color active" data-color="#404040" title="Dark"></button>
    <button class="toolbar-color" data-color="#EA6A2F" title="Orange"></button>
    <button class="toolbar-color" data-color="#0B74DA" title="Blue"></button>
    <button class="toolbar-color" data-color="#7346DD" title="Purple"></button>
  </div>
</div>

<style>
  .toolbar {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 8px 12px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-primary);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    pointer-events: auto;
  }

  .toolbar-mode {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border: none;
    border-radius: var(--radius-pill);
    background: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }

  .toolbar-mode:hover {
    color: var(--color-text-primary);
  }

  .toolbar-mode.active {
    background: var(--color-bg-active);
    color: var(--color-text-primary);
  }

  .toolbar-divider {
    width: 1px;
    height: 24px;
    background: var(--color-border-secondary);
    border-radius: var(--radius-pill);
    flex-shrink: 0;
    margin: 0 8px;
  }

  .toolbar-colors {
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: 0;
    margin-left: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-width 0.3s ease, opacity 0.2s ease, margin 0.3s ease;
  }

  .toolbar-colors.visible {
    max-width: 120px;
    margin-left: 8px;
    opacity: 1;
  }

  .toolbar-color {
    width: 16px;
    height: 16px;
    border-radius: var(--radius-pill);
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 0.25;
    transition: opacity 0.12s ease;
    flex-shrink: 0;
  }

  .toolbar-color[data-color="#404040"] { background: var(--color-text-primary); }
  .toolbar-color[data-color="#EA6A2F"] { background: var(--color-orange-accent); }
  .toolbar-color[data-color="#0B74DA"] { background: var(--color-blue-accent); }
  .toolbar-color[data-color="#7346DD"] { background: var(--color-purple-accent); }

  .toolbar-color.active {
    opacity: 1;
  }

  .toolbar-color:hover {
    opacity: 0.6;
  }

  .toolbar-color.active:hover {
    opacity: 1;
  }

  /* ─── Tooltip ─── */

  .tooltip {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 8px;
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-secondary);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    font-size: 12px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0.24px;
    color: var(--color-text-secondary);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .toolbar-mode:hover .tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    transition-delay: 0.4s;
  }

  .tooltip kbd {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 15px;
    height: 15px;
    padding: 0 3px;
    background: var(--color-bg-active);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 10px;
    font-weight: 500;
    line-height: 10px;
    letter-spacing: 0.2px;
    color: var(--color-text-secondary);
    text-align: center;
  }

  @media (max-width: 768px) {
    .toolbar { display: none; }
  }
</style>
