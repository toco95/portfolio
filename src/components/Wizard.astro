---
interface Slide {
  title: string;
  body: string;
  desktopOnly?: boolean;
}

const slides: Slide[] = [
  {
    title: 'Welcome',
    body: 'An infinite canvas portfolio inspired by Figma, free to explore.',
  },
  {
    title: 'Move around',
    body: 'Drag the canvas to pan around, scroll or pinch to zoom in and out.',
  },
  {
    title: 'Jump between projects',
    body: 'Use the section nav to jump from one piece of work to the next.',
  },
  {
    title: 'Make it yours',
    body: 'The toolbar lets you draw, scatter emojis, and move things around.',
    desktopOnly: true,
  },
];
---

<aside class="wizard" data-wizard data-slides={JSON.stringify(slides)} aria-live="polite">
  <button type="button" class="wizard-close" data-wizard-close aria-label="Dismiss">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M12.5 3.5L3.5 12.5M3.5 3.5L12.5 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <h3 class="wizard-title" data-wizard-title></h3>
  <p class="wizard-body" data-wizard-body></p>

  <div class="wizard-footer">
    <div class="wizard-arrows">
      <button type="button" class="wizard-arrow" data-wizard-prev aria-label="Previous">
        <svg width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"/>
        </svg>
      </button>
      <button type="button" class="wizard-arrow" data-wizard-next aria-label="Next">
        <svg width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"/>
        </svg>
      </button>
    </div>
    <div class="wizard-dots" data-wizard-dots></div>
  </div>
</aside>

<style>
  .wizard {
    position: fixed;
    bottom: var(--space-5);
    right: var(--space-5);
    width: 280px;
    padding: var(--space-3);
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-secondary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    z-index: 90;

    /* Animate in: matches the landing intro motion (blur + rise). */
    opacity: 0;
    transform: translateY(10px);
    filter: blur(10px);
    pointer-events: none;
    transition:
      opacity   900ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1),
      filter    900ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .wizard.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
    pointer-events: auto;
  }

  /* Hidden until JS decides to show it (keeps SSR markup but no flash). */
  .wizard:not(.mounted) { display: none; }

  @media (max-width: 768px) {
    .wizard {
      top: 80px;
      bottom: auto;
      left: var(--space-5);
      right: var(--space-5);
      width: auto;
      max-width: none;
    }
  }

  .wizard-close {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    padding: 0;
    background: none;
    border: none;
    border-radius: var(--radius-md);
    color: var(--color-text-tertiary);
    cursor: pointer;
    transition: color 0.12s ease, background 0.12s ease;
  }

  .wizard-close:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-hover);
  }

  .wizard-title {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-text-primary);
    margin: 0 28px 6px 0; /* clear the close button */
  }

  .wizard-body {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3);
  }

  .wizard-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .wizard-arrows {
    display: flex;
    gap: 2px;
  }

  .wizard-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    background: none;
    border: none;
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: color 0.12s ease, background 0.12s ease, opacity 0.12s ease;
  }

  .wizard-arrow:hover:not(:disabled) {
    color: var(--color-text-primary);
    background: var(--color-bg-hover);
  }

  .wizard-arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .wizard-dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .wizard-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border-secondary);
    transition: background 0.15s ease;
  }

  .wizard-dot.active {
    background: var(--color-text-primary);
  }
</style>

<script>
  interface Slide {
    title: string;
    body: string;
    desktopOnly?: boolean;
  }

  const SESSION_KEY = 'wizardSeen';
  const SPLASH_KEY = 'designSplashSeen';

  function initWizard() {
    const wizard = document.querySelector<HTMLElement>('[data-wizard]');
    if (!wizard) return;

    // Skip entirely if the user has already seen it this session.
    try {
      if (sessionStorage.getItem(SESSION_KEY)) return;
    } catch {}

    // First-visit flow: the splash covers the canvas on first load, so defer
    // the wizard until the splash dismisses. DesignSplash fires
    // `design-splash-dismissed` when the user picks a section / starts roaming.
    // Wait ~500ms after the dismiss event so the splash is mostly faded out
    // before the wizard starts its own entrance animation (splash transition
    // is 600ms total).
    try {
      if (!sessionStorage.getItem(SPLASH_KEY)) {
        window.addEventListener('design-splash-dismissed', () => {
          window.setTimeout(() => initWizard(), 500);
        }, { once: true });
        return;
      }
    } catch {}

    const allSlides: Slide[] = JSON.parse(wizard.dataset.slides ?? '[]');
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const slides = isMobile ? allSlides.filter((s) => !s.desktopOnly) : allSlides;
    if (slides.length === 0) return;

    const titleEl = wizard.querySelector<HTMLElement>('[data-wizard-title]');
    const bodyEl = wizard.querySelector<HTMLElement>('[data-wizard-body]');
    const dotsEl = wizard.querySelector<HTMLElement>('[data-wizard-dots]');
    const prevBtn = wizard.querySelector<HTMLButtonElement>('[data-wizard-prev]');
    const nextBtn = wizard.querySelector<HTMLButtonElement>('[data-wizard-next]');
    const closeBtn = wizard.querySelector<HTMLButtonElement>('[data-wizard-close]');

    // Build dot indicators
    if (dotsEl) {
      dotsEl.innerHTML = '';
      slides.forEach(() => {
        const dot = document.createElement('span');
        dot.className = 'wizard-dot';
        dotsEl.appendChild(dot);
      });
    }
    const dots = dotsEl ? Array.from(dotsEl.children) as HTMLElement[] : [];

    let index = 0;
    const render = () => {
      const slide = slides[index];
      if (titleEl) titleEl.textContent = slide.title;
      if (bodyEl) bodyEl.textContent = slide.body;
      dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
      if (prevBtn) prevBtn.disabled = index === 0;
      if (nextBtn) nextBtn.disabled = index === slides.length - 1;
    };

    const dismiss = () => {
      try { sessionStorage.setItem(SESSION_KEY, '1'); } catch {}
      wizard.classList.remove('visible');
      // Allow the fade-out to finish before removing from layout.
      window.setTimeout(() => wizard.classList.remove('mounted'), 600);
    };

    prevBtn?.addEventListener('click', () => {
      if (index > 0) { index--; render(); }
    });
    nextBtn?.addEventListener('click', () => {
      if (index < slides.length - 1) { index++; render(); }
    });
    closeBtn?.addEventListener('click', dismiss);

    render();

    // Reveal immediately, alongside the rest of the page chrome. The double
    // RAF ensures the browser commits the initial (blurred) state before the
    // transition fires, so the blur+rise animation actually plays.
    wizard.classList.add('mounted');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => wizard.classList.add('visible'));
    });
  }

  document.addEventListener('astro:page-load', initWizard);
</script>
