---
interface Props {
  id: string;
  title: string;
  description: string;
  category: string;
  date: Date;
  hasDetailPage: boolean;
  externalUrl?: string;
  cover?: string;
}

const { id, title, description, category, date, hasDetailPage, externalUrl, cover } = Astro.props;

const href = hasDetailPage
  ? `/projects/${id}`
  : externalUrl || '#';

const isExternal = !hasDetailPage && !!externalUrl;

const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---

<a
  href={href}
  class="group block overflow-hidden rounded-md bg-bg-card transition-colors hover:bg-bg-card-hover"
  {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  {cover ? (
    <img src={cover} alt={title} class="w-full h-auto" />
  ) : (
    <div class="aspect-[16/10] w-full bg-border-secondary" />
  )}

  <div class="p-4">
    <h3 class="flex items-center text-lg gap-1.5 font-medium leading-snug">
      {title}
      {isExternal && (
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor" class="shrink-0 text-text-secondary"><path d="M208,34H48A14,14,0,0,0,34,48V208a14,14,0,0,0,14,14H208a14,14,0,0,0,14-14V48A14,14,0,0,0,208,34Zm2,174a2,2,0,0,1-2,2H48a2,2,0,0,1-2-2V48a2,2,0,0,1,2-2H208a2,2,0,0,1,2,2ZM166,96v48a6,6,0,0,1-12,0V110.48l-53.76,53.76a6,6,0,0,1-8.48-8.48L145.52,102H112a6,6,0,0,1,0-12h48A6,6,0,0,1,166,96Z"/></svg>
      )}
    </h3>
    <p class="mt-1 text-base leading-relaxed text-text-secondary">{description}</p>
    <p class="mt-2 text-sm text-text-tertiary">{category} — {formattedDate}</p>
  </div>
</a>
