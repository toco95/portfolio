---
import Icon from './Icon.astro';

interface HovercardLink {
  href: string;
  label: string;
  /** Defaults to true when href starts with http(s)://. */
  external?: boolean;
}

interface Props {
  description: string;
  image?: string;
  imageAlt?: string;
  links?: HovercardLink[];
  /** Where the card opens.
      'side' (default) — floats out into the left-hand whitespace, vertically
      centered on the trigger. Automatically falls back to 'top' when there
      isn't enough room on the left (e.g. mobile / narrow viewports).
      'top' — stacked above (or below) the trigger, centered on it. */
  placement?: 'top' | 'side';
}

const { description, image, imageAlt = '', links = [], placement = 'side' } = Astro.props;

const isExternal = (href: string) =>
  href.startsWith('http://') || href.startsWith('https://');
---

<span class="hovercard-trigger" data-hovercard data-placement={placement}>
  <slot />
  <span class="hovercard" role="tooltip">
    {/* Contents stay `display: none` until first interaction (toggled by the
        `data-ready` attribute on the trigger). Keeps the Hovercard image and
        children out of initial paint — without this, Safari mobile defers
        paint of the parent element (e.g. the about-page tagline) until the
        whole subtree is ready, which makes the parent's intro animation
        appear "stuck" or arrive late. */}
    <span class="hovercard-body">
      {image && (
        <img
          src={image}
          alt={imageAlt}
          class="hovercard-image"
          loading="lazy"
          decoding="async"
        />
      )}
      <span class="hovercard-text">{description}</span>
      {links.map((link) => {
        const ext = link.external ?? isExternal(link.href);
        return (
          <a
            href={link.href}
            target={ext ? '_blank' : undefined}
            rel={ext ? 'noopener noreferrer' : undefined}
            class="hovercard-link"
          >
            {link.label}
            <Icon name="arrow-up-right" size={16} />
          </a>
        );
      })}
    </span>
  </span>
</span>

<style>
  .hovercard-trigger {
    position: relative;
    /* No click affordance — the card opens on hover, so keep the default
       cursor rather than the pointer/hand. */
    cursor: default;
    border-bottom: 1.5px solid var(--color-border-primary);
    color: inherit;
    transition: color 0.15s ease, border-bottom-color 0.15s ease;
  }

  .hovercard-trigger:hover,
  .hovercard-trigger.open {
    color: var(--color-text-primary);
    border-bottom-color: var(--color-text-secondary);
  }

  .hovercard {
    position: absolute;
    bottom: calc(100% + var(--space-3));
    left: 0;
    width: max-content;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: var(--space-3);
    background: var(--color-bg-element);
    border: 0.5px solid var(--color-border-secondary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    transform: translateY(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 10;
  }

  .hovercard.below {
    bottom: auto;
    top: calc(100% + var(--space-3));
    transform: translateY(-4px);
  }

  /* Side placement: the card floats to the LEFT of the trigger, out in the
     page margin. JS sets the exact left/top (the card is measured first so it
     can be vertically centered on the trigger and clamped to the viewport). */
  .hovercard.side {
    bottom: auto;
    transform: translateX(4px);
  }

  /* Invisible bridge over the 12px gap so the cursor stays on a hoverable
     surface while moving from trigger to card. */
  .hovercard::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 12px;
    bottom: -12px;
  }

  .hovercard.below::before {
    bottom: auto;
    top: -12px;
  }

  /* Bridge sits on the card's right edge (the gap faces the trigger). */
  .hovercard.side::before {
    left: auto;
    right: -12px;
    top: 0;
    bottom: 0;
    width: 12px;
    height: auto;
  }

  /* Lazy-mount the panel contents: hidden until the trigger has been
     interacted with at least once. `display: contents` makes the wrapper
     transparent in layout so the children remain direct flex items of
     `.hovercard`. */
  .hovercard-body { display: none; }
  .hovercard-trigger[data-ready] .hovercard-body { display: contents; }

  /* `.suppress` is added on scroll so a hovered card collapses even while the
     pointer is still resting on the trigger; it's cleared on the next pointer
     move (see script). */
  .hovercard-trigger:hover:not(.suppress) .hovercard,
  .hovercard-trigger.open .hovercard {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition-delay: 0.1s;
  }

  .hovercard-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    display: block;
  }

  .hovercard-text {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-secondary);
  }

  .hovercard-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    align-self: flex-start;
  }

  /* :global() so the rule reaches the SVG rendered by the Icon component
     (it lives in its own style scope and so doesn't carry this file's cid). */
  .hovercard-link :global(svg) {
    color: var(--color-text-tertiary);
    transition: color 0.15s ease;
  }

  .hovercard-link:hover :global(svg) {
    color: var(--color-text-primary);
  }
</style>

<script>
  function initHovercards() {
    const triggers = document.querySelectorAll<HTMLElement>('[data-hovercard]');
    const MARGIN = 12;
    // Hover-capable (pointer) devices open the card on hover, so clicking must
    // not latch it open. Only touch devices, which have no hover, get the
    // click-to-open toggle below.
    const canHover = window.matchMedia('(hover: hover)').matches;

    function placeCard(trigger: HTMLElement) {
      const card = trigger.querySelector<HTMLElement>('.hovercard');
      if (!card) return;
      const triggerRect = trigger.getBoundingClientRect();
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const cardW = card.offsetWidth || 280;
      const cardH = card.offsetHeight || 320;

      // Reset variant state — recomputed fresh every time so a card that fell
      // back to stacked on a narrow viewport can return to side when resized.
      card.classList.remove('below', 'side');
      card.style.top = '';

      // Side placement: float the card into the left-hand whitespace, centered
      // vertically on the trigger. Only when there's genuine room on the left
      // (desktop); otherwise fall through to the stacked layout below (mobile).
      if (trigger.dataset.placement === 'side' && triggerRect.left >= cardW + MARGIN * 2) {
        card.classList.add('side');
        const left = triggerRect.left - MARGIN - cardW;
        card.style.left = `${left - triggerRect.left}px`;
        const top = Math.max(
          MARGIN,
          Math.min(vh - cardH - MARGIN, triggerRect.top + triggerRect.height / 2 - cardH / 2),
        );
        card.style.top = `${top - triggerRect.top}px`;
        return;
      }

      // Stacked placement: above the trigger, flipping below when there isn't
      // room. Centered horizontally on the trigger and clamped to the viewport
      // so a 280px card never spills off-screen (matters on mobile).
      const spaceAbove = triggerRect.top;
      const spaceBelow = vh - triggerRect.bottom;
      const placeBelow = spaceAbove < cardH + MARGIN && spaceBelow > spaceAbove;
      card.classList.toggle('below', placeBelow);

      const desiredLeft = triggerRect.left + triggerRect.width / 2 - cardW / 2;
      const clampedLeft = Math.max(
        MARGIN,
        Math.min(vw - cardW - MARGIN, desiredLeft),
      );
      card.style.left = `${clampedLeft - triggerRect.left}px`;
    }

    function closeAll(except?: HTMLElement) {
      triggers.forEach((t) => {
        if (t !== except) t.classList.remove('open');
      });
    }

    // First interaction unhides the panel contents (see `.hovercard-body` in
    // the stylesheet). Must run before placeCard so offsetWidth/Height are
    // non-zero when the position is measured.
    function markReady(trigger: HTMLElement) {
      if (!trigger.hasAttribute('data-ready')) {
        trigger.setAttribute('data-ready', '');
      }
    }

    // ─── Hover-intent "safe polygon" ────────────────────────────────────────
    // When the cursor leaves the trigger, the card (a child, so :hover normally
    // keeps it visible) can still snap shut on the diagonal trip across the gap
    // to a side-placed card. To fix that, on mouseleave we hold the card open
    // (via `.open`) as long as the cursor stays inside the triangle aimed from
    // the leave point at the card's corners — i.e. as long as it keeps moving
    // toward the card. Step out of that polygon (or stall) and it closes.
    type Pt = { x: number; y: number };

    function convexHull(points: Pt[]): Pt[] {
      const pts = points.slice().sort((a, b) => a.x - b.x || a.y - b.y);
      const cross = (o: Pt, a: Pt, b: Pt) =>
        (a.x - o.x) * (b.y - o.y) - (a.y - o.y) * (b.x - o.x);
      const lower: Pt[] = [];
      for (const p of pts) {
        while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], p) <= 0) lower.pop();
        lower.push(p);
      }
      const upper: Pt[] = [];
      for (let i = pts.length - 1; i >= 0; i--) {
        const p = pts[i];
        while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], p) <= 0) upper.pop();
        upper.push(p);
      }
      lower.pop();
      upper.pop();
      return lower.concat(upper);
    }

    function pointInPolygon(x: number, y: number, poly: Pt[]): boolean {
      let inside = false;
      for (let i = 0, j = poly.length - 1; i < poly.length; j = i++) {
        const xi = poly[i].x, yi = poly[i].y, xj = poly[j].x, yj = poly[j].y;
        const hit = (yi > y) !== (yj > y) && x < ((xj - xi) * (y - yi)) / (yj - yi) + xi;
        if (hit) inside = !inside;
      }
      return inside;
    }

    let graceMove: ((e: MouseEvent) => void) | null = null;
    let graceTimer = 0;

    function clearGrace() {
      if (graceMove) {
        document.removeEventListener('mousemove', graceMove);
        graceMove = null;
      }
      if (graceTimer) {
        window.clearTimeout(graceTimer);
        graceTimer = 0;
      }
    }

    triggers.forEach((trigger) => {
      const card = trigger.querySelector<HTMLElement>('.hovercard');

      trigger.addEventListener('mouseenter', () => {
        clearGrace();
        trigger.classList.remove('open'); // hand visibility back to :hover
        closeAll(trigger);
        markReady(trigger);
        placeCard(trigger);
      });
      trigger.addEventListener('focusin', () => {
        markReady(trigger);
        placeCard(trigger);
      });

      if (canHover && card) {
        trigger.addEventListener('mouseleave', (e) => {
          if (!trigger.hasAttribute('data-ready')) return;
          const rect = card.getBoundingClientRect();
          if (rect.width === 0 || rect.height === 0) return;
          const hull = convexHull([
            { x: e.clientX, y: e.clientY },
            { x: rect.left, y: rect.top },
            { x: rect.right, y: rect.top },
            { x: rect.right, y: rect.bottom },
            { x: rect.left, y: rect.bottom },
          ]);
          clearGrace();
          trigger.classList.add('open'); // hold open past :hover, no flicker

          const closeNow = () => {
            clearGrace();
            trigger.classList.remove('open');
          };
          // Auto-close only after the pointer sits *idle* in the corridor —
          // reset on every move so travelling toward the (far, side-placed)
          // card at any speed keeps it open. A hard deadline here would close
          // the card mid-journey, which is the annoying part.
          const armIdleClose = () => {
            if (graceTimer) window.clearTimeout(graceTimer);
            graceTimer = window.setTimeout(closeNow, 700);
          };

          graceMove = (ev: MouseEvent) => {
            // Back over the trigger or its card → let :hover take over again.
            if (trigger.matches(':hover')) {
              closeNow();
              return;
            }
            // Left the aim-at-card corridor → close immediately.
            if (!pointInPolygon(ev.clientX, ev.clientY, hull)) {
              closeNow();
              return;
            }
            // Still heading toward the card — keep open, restart the idle timer.
            armIdleClose();
          };
          document.addEventListener('mousemove', graceMove, { passive: true });
          armIdleClose();
        });
      }

      if (!canHover) {
        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = trigger.classList.contains('open');
          closeAll(trigger);
          if (!isOpen) {
            markReady(trigger);
            placeCard(trigger);
            trigger.classList.add('open');
          }
        });
      }
    });

    document.addEventListener('click', () => closeAll());

    // Close on scroll: drop any click-opened card and suppress the CSS :hover
    // state so a card under a resting pointer collapses too. Capture phase so
    // nested scroll containers (e.g. the canvas) trigger it. The suppression is
    // lifted on the next pointer move so the card can re-open naturally.
    let suppressed = false;
    document.addEventListener('scroll', () => {
      clearGrace();
      closeAll();
      triggers.forEach((t) => t.classList.add('suppress'));
      suppressed = true;
    }, { capture: true, passive: true });
    document.addEventListener('pointermove', () => {
      if (!suppressed) return;
      triggers.forEach((t) => t.classList.remove('suppress'));
      suppressed = false;
    }, { passive: true });

    window.addEventListener('resize', () => {
      triggers.forEach((t) => {
        if (t.matches(':hover') || t.classList.contains('open')) placeCard(t);
      });
    });
  }

  document.addEventListener('astro:page-load', initHovercards);
</script>
