---
import Button from './Button.astro';
---

<section class="py-0">
  <img src="/profile.webp" alt="Thomas Cochet" class="mb-6 h-16 w-16 rounded-lg object-cover" />

  <h1 class="text-3xl font-medium">Thomas Cochet — Toco</h1>
  <p class="mt-2 text-xl text-text-secondary">Product Designer based in Paris, France</p>

  <div class="mt-4 flex items-center gap-3">
    <Button href="https://linkedin.com/in/thomascochet" label="LinkedIn" external />
    <Button href="https://cal.com/thomascochet" label="Book a call" external />
  </div>

    <!-- Current role -->
    <div class="mt-10">
      <p class="text-sm font-medium text-text-tertiary">Current position</p>
      <div class="mt-4 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
        <img src="/hyperline-icon.png" alt="Hyperline" class="h-12 w-12 rounded-lg" />
        <div>
          <p class="text-lg font-medium">Founding Designer at Hyperline</p>
          <p class="mt-1 text-base text-text-secondary">Building the future of revenue management</p>
        </div>
      </div>
    </div>

  <!-- hidden for now
  <div class="mt-4">
    <span class="inline-flex items-center gap-2 rounded-full border border-border-secondary px-3 py-1.5 text-xs text-text-tertiary">
      <span class="h-1.5 w-1.5 rounded-full bg-text-tertiary" />
      Not available for new projects
    </span>
  </div>
-->
  <p class="mt-10 text-sm font-medium text-text-tertiary">About me</p>
  <p class="mt-4 leading-relaxed text-text-secondary">
    I'm a product designer with a business mindset, passionate about crafting products that balance user experience with strategic impact. Currently shaping the future of revenue management as Founding Designer at Hyperline.
  </p>
  <p class="mt-4 leading-relaxed text-text-secondary">
    I'm a multi-disciplinary creative, building brand identities, designing websites, drawing illustrations and capturing stories through photography.
  </p>

</section>
