---
interface Props {
  text: string;
  available?: boolean;
}

const { text, available = false } = Astro.props;
---

<span class="inline-flex items-center gap-2 rounded-full border border-border-secondary px-3 py-1.5 text-xs text-text-secondary">
  <span class:list={[
    'h-1.5 w-1.5 rounded-full',
    available ? 'bg-green-400' : 'bg-text-secondary',
  ]} />
  {text}
</span>
