---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);

const groups = ['Hyperline', 'Shine', 'Freelance'] as const;
---

{groups.map(group => {
  const projects = sorted.filter(p => p.data.group === group);
  if (projects.length === 0) return null;
  return (
    <section class="py-0">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-xl font-medium">{group}</h2>
      </div>

      <div class="grid gap-6">
        {projects.map(project => (
          <ProjectCard
            id={project.id}
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            date={project.data.date}
            hasDetailPage={project.data.hasDetailPage}
            externalUrl={project.data.externalUrl}
            cover={project.data.cover}
          />
        ))}
      </div>
    </section>
  );
})}
