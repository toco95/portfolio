---
const currentPath = Astro.url.pathname;

const links = [
  {
    href: '/',
    label: 'Home',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor"><path d="M217.9,110.1l-80-80a14,14,0,0,0-19.8,0l-80,80A13.92,13.92,0,0,0,34,120v96a6,6,0,0,0,6,6h64a6,6,0,0,0,6-6V158h36v58a6,6,0,0,0,6,6h64a6,6,0,0,0,6-6V120A13.92,13.92,0,0,0,217.9,110.1ZM210,210H158V152a6,6,0,0,0-6-6H104a6,6,0,0,0-6,6v58H46V120a2,2,0,0,1,.58-1.42l80-80a2,2,0,0,1,2.84,0l80,80A2,2,0,0,1,210,120Z"/></svg>`,
    dividerAfter: true,
  },
  {
    href: '/track-record',
    label: 'Track Record',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor"><path d="M232,66H206V48a6,6,0,0,0-6-6H56a6,6,0,0,0-6,6V66H24A14,14,0,0,0,10,80V96a38,38,0,0,0,38,38h5.14A78,78,0,0,0,122,189.75V218H96a6,6,0,0,0,0,12h64a6,6,0,0,0,0-12H134V189.75c32.44-2.52,59.43-25.3,68.62-55.75H208a38,38,0,0,0,38-38V80A14,14,0,0,0,232,66ZM48,122A26,26,0,0,1,22,96V80a2,2,0,0,1,2-2H50v34a80.87,80.87,0,0,0,.65,10Zm146-10.9c0,36.62-29.38,66.63-65.5,66.9A66,66,0,0,1,62,112V54H194ZM234,96a26,26,0,0,1-26,26h-2.77a78.45,78.45,0,0,0,.77-10.9V78h26a2,2,0,0,1,2,2Z"/></svg>`,
  },
  {
    href: '/photography',
    label: 'Photography',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor"><path d="M208,58H179.21L165,36.67A6,6,0,0,0,160,34H96a6,6,0,0,0-5,2.67L76.78,58H48A22,22,0,0,0,26,80V192a22,22,0,0,0,22,22H208a22,22,0,0,0,22-22V80A22,22,0,0,0,208,58Zm10,134a10,10,0,0,1-10,10H48a10,10,0,0,1-10-10V80A10,10,0,0,1,48,70H80a6,6,0,0,0,5-2.67L99.21,46h57.57L171,67.33A6,6,0,0,0,176,70h32a10,10,0,0,1,10,10ZM128,90a42,42,0,1,0,42,42A42,42,0,0,0,128,90Zm0,72a30,30,0,1,1,30-30A30,30,0,0,1,128,162Z"/></svg>`,
    dividerAfter: true,
  },
];

const contactIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor"><path d="M224,50H32a6,6,0,0,0-6,6V192a14,14,0,0,0,14,14H216a14,14,0,0,0,14-14V56A6,6,0,0,0,224,50ZM208.58,62,128,135.86,47.42,62ZM216,194H40a2,2,0,0,1-2-2V69.64l86,78.78a6,6,0,0,0,8.1,0L218,69.64V192A2,2,0,0,1,216,194Z"/></svg>`;
---

<nav class="fixed bottom-6 left-1/2 z-50 -translate-x-1/2">
  <div class="flex h-fit items-center gap-1 rounded-2xl bg-bg-nav px-2 py-2 backdrop-blur-2xl saturate-150">
    {links.map(link => {
      const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
      return (
        <>
          <a
            href={link.href}
            class:list={[
              'rounded-lg transition-colors hover:bg-white/10',
              'flex items-center justify-center h-9 w-9 sm:h-auto sm:w-auto sm:px-2.5 sm:py-1.5',
              isActive ? 'bg-white/10 text-text-primary' : 'text-text-secondary hover:text-text-primary',
            ]}
            aria-label={link.label}
          >
            <span class="sm:hidden" set:html={link.icon} />
            <span class="hidden sm:inline whitespace-nowrap text-base font-medium">{link.label}</span>
          </a>
          {link.dividerAfter && (
            <div class="mx-0.5 h-5 w-px bg-border-secondary" />
          )}
        </>
      );
    })}
    <a
      href="mailto:thomas@hyperline.co"
      class:list={[
        'rounded-lg transition-colors hover:bg-white/10',
        'flex items-center justify-center h-9 w-9 sm:h-auto sm:w-auto sm:px-3 sm:py-1.5',
        'text-text-secondary hover:text-text-primary',
      ]}
      aria-label="Contact"
    >
      <span class="sm:hidden" set:html={contactIcon} />
      <span class="hidden sm:inline text-base font-medium">Contact</span>
    </a>
  </div>
</nav>
