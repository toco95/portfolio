---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotographyCard from '../../components/PhotographyCard.astro';

const entries = (await getCollection('photography')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Photography — Thomas Cochet" description="Photography work by Thomas Cochet.">
  <section class="py-0">
    <h1 class="text-2xl font-medium">Photography</h1>
    <p class="mt-2 text-xl text-text-secondary">
      Street photography and documentary projects capturing everyday life.
    </p>
  </section>

  <section class="py-0 grid grid-cols-1 gap-4">
    {entries.map(entry => (
      <PhotographyCard
        id={entry.id}
        title={entry.data.title}
        description={entry.data.description}
        date={entry.data.date}
        cover={entry.data.cover}
      />
    ))}
  </section>
</BaseLayout>
