---
import BaseLayout from '../layouts/BaseLayout.astro';
import Chrome from '../components/canvas/Chrome.astro';
import Hovercard from '../components/Hovercard.astro';
import Icon from '../components/Icon.astro';
import { links } from '../data/links';
import { getCollection } from 'astro:content';

const milestones = await getCollection('milestones');
const sortedMilestones = milestones.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title="Thomas Cochet — Product Designer" description="Product Designer based in Paris, France.">
  <Chrome activePage="about" animateIntro={true} />

  <script>
    function initAccordion() {
      const trigger = document.getElementById('achievements-trigger');
      const content = document.getElementById('achievements-content');
      if (!trigger || !content) return;
      trigger.addEventListener('click', () => {
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', String(!expanded));
        content.classList.toggle('open', !expanded);
      });
    }
    document.addEventListener('astro:page-load', initAccordion);

    function settleIntro() {
      try { sessionStorage.setItem('aboutIntroSeen', '1'); } catch {}
      // Clear the gating class once the last animation has finished so
      // subsequent visits to /about in the same session don't re-trigger.
      // Last delay (chrome) = 880ms, duration = 700ms → ~1.6s.
      window.setTimeout(() => {
        document.documentElement.classList.remove('intro-active');
      }, 1700);
    }
    document.addEventListener('astro:page-load', settleIntro);
  </script>

  <style>
    body { overflow-y: auto; overflow-x: hidden; }

    .about-main {
      max-width: 640px;
      margin: 0 auto;
      padding: var(--space-20);
      display: flex;
      flex-direction: column;
      gap: var(--space-8);
    }

    @media (max-width: 768px) {
      .about-main { padding: var(--space-20) var(--space-6) var(--space-10); }
    }

    /* ─── Header ─── */

    .about-header {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .about-avatar {
      width: 56px;
      height: 56px;
      border-radius: var(--radius-lg);
      object-fit: cover;
    }

    .about-header-text {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .about-name {
      font-family: var(--font-sans);
      font-size: var(--text-xl);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-primary);
      margin: 0;
    }

    .about-tagline {
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-secondary);
      margin: 0;
    }

    /* ─── Sections ─── */

    .about-section {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .about-label {
      font-family: var(--font-sans);
      font-size: var(--text-sm);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-secondary);
      margin: 0;
    }

    /* ─── Current position ─── */

    .about-position {
      display: flex;
      align-items: center;
      gap: var(--space-4);
    }

    .about-position-icon {
      width: 40px;
      height: 40px;
      border-radius: var(--radius-md);
      object-fit: cover;
      flex-shrink: 0;
    }

    .about-position-text {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .about-position-title {
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-primary);
      margin: 0;
    }

    .about-position-subtitle {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-secondary);
      margin: 0;
    }

    /* ─── About text ─── */

    .about-text {
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-secondary);
      margin: 0;
    }

    /* ─── Divider ─── */

    .about-divider {
      width: 80px;
      height: 1px;
      border: none;
      background: var(--color-border-secondary);
      margin: 0;
    }

    /* ─── Achievements (accordion) ─── */

    .about-achievements {
      display: flex;
      flex-direction: column;
    }

    .accordion-trigger {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      align-self: flex-start;
      padding: 0;
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-primary);
      text-align: left;
      transition: color 0.15s ease;
    }

    .accordion-trigger:hover {
      color: var(--color-text-secondary);
    }

    /* Caret: down when closed (default), up when open. */
    .accordion-chevron {
      flex-shrink: 0;
      color: var(--color-text-secondary);
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .accordion-trigger[aria-expanded="true"] .accordion-chevron {
      transform: rotate(180deg);
    }

    .accordion-content {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .accordion-content.open {
      grid-template-rows: 1fr;
    }

    .accordion-inner {
      overflow: clip;
      overflow-clip-margin: 16px;
      min-height: 0;
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    .accordion-content.open .accordion-inner {
      opacity: 1;
      transition-delay: 0.08s;
    }

    .achievements-list {
      list-style: none;
      padding: var(--space-4) 0 0;
      margin: 0;
      display: flex;
      flex-direction: column;
    }

    .achievement-card {
      display: grid;
      grid-template-columns: 64px 1fr;
      gap: var(--space-6);
      padding: var(--space-4);
      margin: 0 -16px;
      border-radius: var(--radius-lg);
      color: inherit;
      text-decoration: none;
      transition: background 0.2s ease;
    }

    .achievement-card--link:hover {
      background: var(--color-bg-hover);
      cursor: pointer;
    }

    .achievement-year {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-tertiary);
      padding-top: 2px;
    }

    .achievement-body {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .achievement-cover {
      width: 100%;
      max-width: 120px;
      height: auto;
      border-radius: var(--radius-md);
      margin-bottom: var(--space-3);
      display: block;
    }

    .achievement-title {
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 500;
      line-height: 1.3;
      color: var(--color-text-primary);
      margin: 0;
    }

    .achievement-title-tail {
      white-space: nowrap;
    }

    .achievement-arrow {
      display: inline-block;
      vertical-align: -1px;
      margin-left: var(--space-1);
      color: var(--color-text-tertiary);
    }

    .achievement-description {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.4;
      color: var(--color-text-secondary);
      margin: 0;
    }

    @media (max-width: 768px) {
      .achievement-card {
        grid-template-columns: 1fr;
        gap: var(--space-1);
      }
    }

    /* ─── Intro animation ─── */

    @keyframes about-fade-up {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    html.intro-active .about-avatar,
    html.intro-active .about-name,
    html.intro-active .about-tagline,
    html.intro-active .about-position,
    html.intro-active .about-text,
    html.intro-active .about-achievements {
      animation: about-fade-up 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
    }

    html.intro-active .about-avatar   { animation-delay:   0ms; }
    html.intro-active .about-name     { animation-delay:  80ms; }
    html.intro-active .about-tagline  { animation-delay: 160ms; }
    html.intro-active .about-position { animation-delay: 280ms; }

    html.intro-active .about-text:nth-of-type(1) { animation-delay: 400ms; }
    html.intro-active .about-text:nth-of-type(2) { animation-delay: 480ms; }
    html.intro-active .about-text:nth-of-type(3) { animation-delay: 560ms; }

    html.intro-active .about-achievements { animation-delay: 640ms; }

    @media (prefers-reduced-motion: reduce) {
      html.intro-active .about-avatar,
      html.intro-active .about-name,
      html.intro-active .about-tagline,
      html.intro-active .about-position,
      html.intro-active .about-text,
      html.intro-active .about-achievements {
        animation: none;
      }
    }
  </style>

  <main class="about-main">
    <!-- Header -->
    <div class="about-header">
      <img src="/images/icons/profile.webp" alt="Thomas Cochet" width="56" height="56" loading="eager" decoding="async" class="about-avatar" />
      <div class="about-header-text">
        <h1 class="about-name">Thomas Cochet</h1>
        <p class="about-tagline">Product Designer based in <Hovercard
          description="A few of my Paris favorites"
          links={[
            { href: links.paris.cafes,       label: 'Cafés' },
            { href: links.paris.restaurants, label: 'Restaurants' },
            { href: links.paris.bars,        label: 'Bars' },
          ]}
        >Paris</Hovercard></p>
      </div>
    </div>

    <!-- Current position -->
    <div class="about-section">
      <div class="about-position">
        <img src="/images/icons/hyperline.svg" alt="Hyperline" width="40" height="40" loading="lazy" decoding="async" class="about-position-icon" />
        <div class="about-position-text">
          <p class="about-position-title">Founding Designer at <Hovercard
            image="/images/projects/hyperline/analytics.webp"
            description="Hyperline is the modern billing & revenue management platform built for SaaS companies."
            links={[{ href: links.work.hyperline, label: 'Visit website' }]}
          >Hyperline</Hovercard></p>
          <p class="about-position-subtitle">Building the future of revenue management</p>
        </div>
      </div>
    </div>

    <!-- About me -->
    <div class="about-section">
      <p class="about-text">I'm a product designer with a business mindset, working at the intersection of design and product strategy. With half a decade in fintech, I focus on crafting seamless, trustworthy experiences that leave a lasting impression.</p>
      <p class="about-text">I'm a multi-disciplinary creative, building brand identities, designing websites, drawing illustrations and capturing stories through <Hovercard
        image="/images/photography/myanmar/myanmar-01.jpeg"
        description="A long-running side practice — travels, concerts, friends. The camera is how I slow down and pay attention."
        links={[{ href: '/photography', label: 'See the gallery' }]}
      >photography</Hovercard>.</p>
      <p class="about-text">Previously worked at <Hovercard
        image="/images/projects/shine_onboarding/shine-onboarding.webp"
        description="Where I honed my design skills — three years shipping product across the neobank."
        links={[{ href: links.work.shine, label: 'Visit website' }]}
      >Shine</Hovercard>, <Hovercard
        description="Started out as a project manager — the experience precipitated my career change toward product design."
      >BNP Paribas</Hovercard></p>
    </div>

    <!-- Divider -->
    <hr class="about-divider" />

    <!-- Achievements (accordion) -->
    <section class="about-achievements">
      <button class="accordion-trigger" id="achievements-trigger" aria-expanded="false" aria-controls="achievements-content">
        <span>See a few cool things I've done</span>
        <Icon name="caret-down" size={16} class="accordion-chevron" />
      </button>
      <div class="accordion-content" id="achievements-content">
        <div class="accordion-inner">
          <ol class="achievements-list">
            {sortedMilestones.map((milestone) => {
              const Tag = milestone.data.externalUrl ? 'a' : 'div';
              const linkProps = milestone.data.externalUrl
                ? { href: milestone.data.externalUrl, target: '_blank', rel: 'noopener noreferrer' }
                : {};
              // Split the title so the last word + arrow can stay glued together
              // via `white-space: nowrap` — prevents an orphaned arrow on its own line.
              const lastSpace = milestone.data.title.lastIndexOf(' ');
              const titleHead = lastSpace >= 0 ? milestone.data.title.slice(0, lastSpace + 1) : '';
              const titleTail = lastSpace >= 0 ? milestone.data.title.slice(lastSpace + 1) : milestone.data.title;
              return (
                <li class="achievement-row">
                  <Tag {...linkProps} class:list={["achievement-card", milestone.data.externalUrl && "achievement-card--link"]}>
                    <time class="achievement-year">{milestone.data.date.getFullYear()}</time>
                    <div class="achievement-body">
                      {milestone.data.cover && (
                        <img src={milestone.data.cover} alt={milestone.data.title} class="achievement-cover" loading="lazy" decoding="async" />
                      )}
                      <h3 class="achievement-title">
                        {milestone.data.externalUrl ? (
                          <>
                            {titleHead}<span class="achievement-title-tail">{titleTail}<Icon name="arrow-up-right" size={12} class="achievement-arrow" /></span>
                          </>
                        ) : milestone.data.title}
                      </h3>
                      <p class="achievement-description">{milestone.data.description}</p>
                    </div>
                  </Tag>
                </li>
              );
            })}
          </ol>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
