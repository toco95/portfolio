---
import BaseLayout from '../layouts/BaseLayout.astro';
import Chrome from '../components/canvas/Chrome.astro';
import Hovercard from '../components/Hovercard.astro';
import Icon from '../components/Icon.astro';
import { links } from '../data/links';
import { getCollection } from 'astro:content';

const milestones = await getCollection('milestones');
const sortedMilestones = milestones.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title="Thomas Cochet — Product Designer" description="Product Designer based in Paris, France.">
  <Chrome activePage="about" animateIntro={true} />

  <script>
    function settleIntro() {
      try { sessionStorage.setItem('aboutIntroSeen', '1'); } catch {}
      // Clear the gating class once the last animation has finished.
      // Last delay = 1280ms, duration = 900ms → ~2.2s.
      window.setTimeout(() => {
        document.documentElement.classList.remove('intro-active');
      }, 2300);
    }
    document.addEventListener('astro:page-load', settleIntro);
  </script>

  <style>
    body { overflow-y: auto; overflow-x: hidden; }

    .about-main {
      max-width: 640px;
      margin: 0 auto;
      padding: var(--space-20);
      display: flex;
      flex-direction: column;
      gap: var(--space-12);
    }

    /* Tighter grouping for header (name/tagline) + current-position pill. */
    .about-intro {
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
    }

    @media (max-width: 768px) {
      .about-main { padding: var(--space-20) var(--space-6) var(--space-10); }
    }

    /* ─── Header ─── */

    .about-header {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .about-avatar {
      width: 56px;
      height: 56px;
      border-radius: var(--radius-lg);
      object-fit: cover;
    }

    .about-header-text {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .about-name {
      font-family: var(--font-sans);
      font-size: var(--text-xl);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-primary);
      margin: 0;
    }

    .about-tagline {
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-secondary);
      margin: 0;
    }

    /* ─── Sections ─── */

    .about-section {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .about-label {
      font-family: var(--font-sans);
      font-size: var(--text-sm);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-secondary);
      margin: 0;
    }

    /* ─── About text ─── */

    .about-text {
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-primary);
      margin: 0;
    }

    /* ─── Divider ─── */

    /* ─── Experience table ─── */

    .experience-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      padding-bottom: var(--space-3);
      border-bottom: 1px solid var(--color-border-secondary);
    }

    .experience-heading {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-secondary);
      margin: 0;
    }

    .experience-action {
      display: inline-flex;
      align-items: center;
      gap: var(--space-1);
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-secondary);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .experience-action :global(svg) {
      color: var(--color-text-tertiary);
      transition: color 0.15s ease;
    }

    .experience-action:hover,
    .experience-action:hover :global(svg) {
      color: var(--color-text-primary);
    }

    .experience-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .experience-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
    }

    .experience-left {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-primary);
    }

    .experience-icon {
      width: 20px;
      height: 20px;
      border-radius: var(--radius-sm);
      flex-shrink: 0;
      object-fit: cover;
    }

    .experience-tag {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-text-tertiary);
    }

    /* ─── Achievements (accordion) ─── */

    .achievements-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
    }

    .achievement-card {
      display: block;
      padding: var(--space-4);
      margin: 0 -16px;
      border-radius: var(--radius-lg);
      color: inherit;
      text-decoration: none;
      transition: background 0.2s ease;
    }

    .achievement-card--link:hover {
      background: var(--color-bg-hover);
      cursor: pointer;
    }

    .achievement-body {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .achievement-cover {
      width: 100%;
      max-width: 120px;
      height: auto;
      border-radius: var(--radius-md);
      margin-bottom: var(--space-3);
      display: block;
    }

    .achievement-title {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.3;
      color: var(--color-text-primary);
      margin: 0;
    }

    .achievement-title-tail {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      white-space: nowrap;
    }

    .achievement-arrow {
      flex-shrink: 0;
      color: var(--color-text-secondary);
    }

    .achievement-description {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 500;
      line-height: 1.4;
      color: var(--color-text-secondary);
      margin: 0;
    }

    /* ─── Mobile overrides (placed after base rules so they win on source-order) ─── */

    /* ─── Intro animation ─── */

    @keyframes about-fade-up {
      from { opacity: 0; transform: translateY(10px); filter: blur(10px); }
      to   { opacity: 1; transform: translateY(0);    filter: blur(0); }
    }

    /* Mobile: drop the blur in the intro. Multiple elements animating
       `filter: blur` simultaneously overloads low-end GPUs — drops frames and
       makes elements like the tagline (which contains a Hovercard subtree)
       appear "stuck" or load late. Opacity + translateY is enough on small
       screens. */
    @media (max-width: 768px) {
      @keyframes about-fade-up {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    }

    html.intro-active .about-avatar,
    html.intro-active .about-name,
    html.intro-active .about-tagline,
    html.intro-active .about-text,
    html.intro-active .about-experience,
    html.intro-active .about-achievements {
      animation: about-fade-up 900ms cubic-bezier(0.22, 1, 0.36, 1) backwards;
    }

    html.intro-active .about-avatar   { animation-delay:   0ms; }
    html.intro-active .about-name     { animation-delay: 160ms; }
    html.intro-active .about-tagline  { animation-delay: 320ms; }

    html.intro-active .about-text:nth-of-type(1) { animation-delay:  520ms; }
    html.intro-active .about-text:nth-of-type(2) { animation-delay:  700ms; }

    html.intro-active .about-experience   { animation-delay: 880ms; }
    html.intro-active .about-achievements { animation-delay: 1060ms; }

    @media (prefers-reduced-motion: reduce) {
      html.intro-active .about-avatar,
      html.intro-active .about-name,
      html.intro-active .about-tagline,
      html.intro-active .about-text,
      html.intro-active .about-experience,
      html.intro-active .about-achievements {
        animation: none;
      }
    }
  </style>

  <main class="about-main">
    <div class="about-intro">
      <div class="about-header">
        <img src="/images/icons/profile.webp" alt="Thomas Cochet" width="56" height="56" loading="eager" decoding="async" class="about-avatar" />
        <div class="about-header-text">
          <h1 class="about-name">Thomas Cochet</h1>
          <p class="about-tagline">Founding Designer based in <Hovercard
            image="/images/projects/misc/paris.webp"
            description="As a foodie, I've been going around the capital looking for the best snacks, coffee, ice-cream or tapas bar."
            links={[
              { href: links.paris.cafes,       label: '☕ Cafés' },
              { href: links.paris.restaurants, label: '🍽️ Restaurants' },
              { href: links.paris.bars,        label: '🍷 Bars' },
            ]}
          >Paris</Hovercard></p>
        </div>
      </div>

      <div class="about-section">
        <p class="about-text">I design products with a <Hovercard
        image="/images/photography/essec-graduation/essec-graduation-18.jpeg"
        description="Studied management at ESSEC Business School before pivoting into product design."
      >business mindset</Hovercard>, working as an early stage operator at the intersection of product, brand, frontend and strategy.</p>
      <p class="about-text">I'm a multi-disciplinary creative, building brand identities, designing websites, and capturing stories through <Hovercard
        image="/images/photography/myanmar/myanmar-01.jpeg"
        description="A passion dear to my heart since I'm 14, that I turned into a part-time job during my student life."
        links={[{ href: '/photography', label: 'View projects' }]}
      >photography</Hovercard>.</p>
      </div>
    </div>

    <!-- Experience -->
    <div class="about-section about-experience">
      <div class="experience-header">
        <p class="experience-heading">Work</p>
        <a href="/design" class="experience-action">
          View all
          <Icon name="arrow-right" size={14} />
        </a>
      </div>
      <ul class="experience-list">
      <li class="experience-row">
        <span class="experience-left">
          <img src="/images/icons/hyperline.svg" alt="" width="20" height="20" loading="lazy" decoding="async" class="experience-icon" />
          <Hovercard
            image="/images/projects/hyperline/main.webp"
            description="Hyperline is the modern billing & revenue management platform built for SaaS companies."
            links={[
              { href: '/design#hyperline', label: 'See the work' },
              { href: links.work.hyperline, label: 'Visit website' },
            ]}
          >Hyperline</Hovercard>
        </span>
        <span class="experience-tag">2022 - Now</span>
      </li>
      <li class="experience-row">
        <span class="experience-left">
          <img src="/images/icons/shine.png" alt="" width="20" height="20" loading="lazy" decoding="async" class="experience-icon" />
          <Hovercard
            image="/images/projects/shine/shine-cover.webp"
            description="I designed the onboarding flow, the partner marketplace and contributed to the design system, working end-to-end with PMs and engineers."
            links={[{ href: links.work.shine, label: 'Visit website' }]}
          >Shine</Hovercard>
        </span>
        <span class="experience-tag">2021 - 2022</span>
      </li>
      <li class="experience-row">
        <span class="experience-left">
          <img src="/images/icons/freelance.png" alt="" width="20" height="20" loading="lazy" decoding="async" class="experience-icon" />
          <Hovercard
            image="/images/projects/misc/freelance.webp"
            description="Freelance design work across branding, websites, and product, with assorted clients between full-time roles."
            links={[{ href: '/design#misc', label: 'See the work' }]}
          >Freelance</Hovercard>
        </span>
        <span class="experience-tag">2020 - 2021</span>
      </li>
      <li class="experience-row">
        <span class="experience-left">
          <img src="/images/icons/bnp-paribas.png" alt="" width="20" height="20" loading="lazy" decoding="async" class="experience-icon" />
          <Hovercard
            image="/images/projects/misc/bnp-paribas.webp"
            description="Worked as Project Manager to improve customer satisfaction, across all canals. Last corporate experience before shifting to design."
          >BNP Paribas</Hovercard>
        </span>
        <span class="experience-tag">2018 - 2019</span>
      </li>
      <li class="experience-row">
        <span class="experience-left">
          <img src="/images/icons/teamsup.png" alt="" width="20" height="20" loading="lazy" decoding="async" class="experience-icon" />
          <Hovercard
            image="/images/projects/misc/teamsup.webp"
            description="E-learning platform for competitive business school exams, where I led marketing and platform design. Acquired in 2017."
          >TeamSup</Hovercard>
        </span>
        <span class="experience-tag">2017</span>
      </li>
      <li class="experience-row">
        <span class="experience-left">
          <img src="/images/icons/british-airways.png" alt="" width="20" height="20" loading="lazy" decoding="async" class="experience-icon" />
          <Hovercard
            image="/images/projects/misc/british-airways.webp"
            description="Summer internship at OpenSkies, British Airways' New York to Paris subsidiary, working on social media, PR, and brand partnerships."
          >British Airways</Hovercard>
        </span>
        <span class="experience-tag">2016</span>
      </li>
      </ul>
    </div>

    <!-- Highlights -->
    <section class="about-section about-achievements">
      <div class="experience-header">
        <p class="experience-heading">Highlights</p>
      </div>
      <ol class="achievements-list">
        {sortedMilestones.map((milestone) => {
          const Tag = milestone.data.externalUrl ? 'a' : 'div';
          const linkProps = milestone.data.externalUrl
            ? { href: milestone.data.externalUrl, target: '_blank', rel: 'noopener noreferrer' }
            : {};
          // Split the title so the last word + arrow can stay glued together
          // via `white-space: nowrap` — prevents an orphaned arrow on its own line.
          const lastSpace = milestone.data.title.lastIndexOf(' ');
          const titleHead = lastSpace >= 0 ? milestone.data.title.slice(0, lastSpace + 1) : '';
          const titleTail = lastSpace >= 0 ? milestone.data.title.slice(lastSpace + 1) : milestone.data.title;
          return (
            <li class="achievement-row">
              <Tag {...linkProps} class:list={["achievement-card", milestone.data.externalUrl && "achievement-card--link"]}>
                <div class="achievement-body">
                  {milestone.data.cover && (
                    <img src={milestone.data.cover} alt={milestone.data.title} class="achievement-cover" loading="lazy" decoding="async" />
                  )}
                  <h3 class="achievement-title">
                    {milestone.data.externalUrl ? (
                      <>
                        {titleHead}<span class="achievement-title-tail">{titleTail}<Icon name="arrow-up-right" size={16} class="achievement-arrow" /></span>
                      </>
                    ) : milestone.data.title}
                  </h3>
                  <p class="achievement-description">{milestone.data.description}</p>
                </div>
              </Tag>
            </li>
          );
        })}
      </ol>
    </section>
  </main>
</BaseLayout>
