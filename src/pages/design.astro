---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import CanvasElement from '../components/canvas/CanvasElement.astro';
import Chrome from '../components/canvas/Chrome.astro';
import Toolbar from '../components/canvas/Toolbar.astro';
import SectionNav from '../components/canvas/SectionNav.astro';
import DesignSplash from '../components/canvas/DesignSplash.astro';
import Wizard from '../components/Wizard.astro';
import canvasElements from '../data/canvas-elements.json';

const projects = await getCollection('projects');

// Named viewports drive the section nav AND deep-links (e.g. /design#hyperline).
// The 'initial' id (if present) sets the default framing on first load.
const viewportElements = canvasElements
  .filter((el: any) => el.type === 'viewport' && el.id)
  .map((el: any) => ({
    id: el.id as string,
    label: (el.label as string) ?? el.id,
    x: el.x as number,
    y: el.y as number,
    width: el.width as number,
    height: el.height as number,
  }));

const namedViewports = Object.fromEntries(
  viewportElements.map((el) => [el.id, { x: el.x, y: el.y, width: el.width, height: el.height }]),
);
const initialViewport = namedViewports.initial;
const navSections = viewportElements.filter((el) => el.id !== 'initial');
---

<BaseLayout
  title="Design — Thomas Cochet"
  description="Selected design work by Thomas Cochet."
  preloadImages={['/images/projects/misc/canvas-preview.webp']}
>
  <Chrome activePage="design" />
  <Toolbar />
  <SectionNav sections={navSections} />
  <Wizard />
  <DesignSplash sections={navSections} />

  <div
    id="canvas-viewport"
    data-initial-viewport={initialViewport ? JSON.stringify(initialViewport) : undefined}
    data-named-viewports={JSON.stringify(namedViewports)}
  >
    <div id="canvas-world">
      {canvasElements.map((el: any) => (
        <CanvasElement element={el} projects={projects} />
      ))}
    </div>
    <div id="draw-layer" class="draw-layer"></div>
  </div>

  {/* Pre-rendered MDX for modal */}
  {await Promise.all(
    projects
      .filter(p => p.data.hasDetailPage)
      .map(async (p) => {
        const { Content } = await render(p);
        return (
          <template data-project={p.id}>
            <div class="prose">
              <h1 class="modal-title">{p.data.title}</h1>
              <div class="modal-meta-row">
                <p class="modal-subtitle">{p.data.group}</p>
                <p class="modal-year">{p.data.date.getFullYear()}</p>
              </div>
              {p.data.cover && (
                <img src={p.data.cover} alt={p.data.title} class="modal-cover" />
              )}
              <Content />
            </div>
          </template>
        );
      })
  )}

  <div id="project-modal">
    <div id="modal-backdrop"></div>
    <button id="modal-close" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M12.5 3.5L3.5 12.5M3.5 3.5L12.5 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div id="modal-content-wrapper">
      <div id="modal-content"></div>
    </div>
  </div>

  <script>
    import { initCanvas } from '../scripts/canvas';
    import { initModal } from '../scripts/modal';

    function init() {
      const viewport = document.getElementById('canvas-viewport');
      const namedRaw = viewport?.dataset.namedViewports;
      const named = namedRaw ? JSON.parse(namedRaw) : {};
      const hashId = window.location.hash.replace(/^#/, '');
      const initialRaw = viewport?.dataset.initialViewport;
      const viewportRect = (hashId && named[hashId]) || (initialRaw ? JSON.parse(initialRaw) : undefined);
      initCanvas(viewportRect);
      initModal();

      // Settle the first-visit intro: mark seen immediately so a navigation
      // mid-animation doesn't replay it; clear the gating class once the
      // ~1.5s blur transition has finished (1400ms duration + 120ms delay).
      if (document.documentElement.classList.contains('design-intro-active')) {
        try { sessionStorage.setItem('designIntroSeen', '1'); } catch {}
        window.setTimeout(() => {
          document.documentElement.classList.remove('design-intro-active');
        }, 1700);
      }
    }

    document.addEventListener('astro:page-load', init);
  </script>
</BaseLayout>
