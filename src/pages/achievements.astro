---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const milestones = await getCollection('milestones');
const sorted = milestones.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function getYear(date: Date) {
  return date.getFullYear().toString();
}
---

<BaseLayout title="Achievements — Thomas Cochet" description="Key milestones in my design career.">
  <!-- Close button -->
  <button class="achievements-close" aria-label="Close" onclick="history.back()">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M12.5 3.5L3.5 12.5M3.5 3.5L12.5 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
  <style>
    body { overflow-y: auto; overflow-x: hidden; }

    .achievements-close {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: var(--color-bg-element);
      border: 0.5px solid var(--color-border-primary);
      border-radius: var(--radius-pill);
      box-shadow: var(--shadow-md);
      color: var(--color-text-secondary);
      cursor: pointer;
      transition: background 0.15s ease;
    }

    .achievements-close:hover {
      background: var(--color-bg-hover);
    }
    .achievements-main { max-width: 640px; margin: 0 auto; padding: 80px; }

    .timeline-card {
      padding: 16px;
      margin-left: -16px;
      margin-right: -16px;
      border-radius: 12px;
      transition: background 0.2s ease;
    }

    .timeline-card--link:hover {
      background: var(--color-bg-hover);
    }

    @media (max-width: 768px) {
      .achievements-main { padding: 80px 24px 40px; }
      .timeline-card { grid-template-columns: 1fr; gap: 0; }
      .timeline-card time { margin-bottom: 8px; }
    }
  </style>
  <main class="achievements-main">
  <section class="py-0">
    <h1 class="text-xl font-medium">Achievements</h1>
    <p class="mt-2 text-lg font-medium text-text-secondary">Key milestones along the way</p>

    <div class="mt-10">
      {sorted.map((milestone) => {
        const Tag = milestone.data.externalUrl ? 'a' : 'div';
        const linkProps = milestone.data.externalUrl
          ? { href: milestone.data.externalUrl, target: '_blank', rel: 'noopener noreferrer' }
          : {};
        return (
          <Tag {...linkProps} class:list={["timeline-card grid grid-cols-[80px_1fr] gap-x-8 py-6", milestone.data.externalUrl && "timeline-card--link group cursor-pointer"]}>
            <time class="text-base font-medium text-text-tertiary pt-0.5">{getYear(milestone.data.date)}</time>

            <div>
              {milestone.data.cover && (
                <img src={milestone.data.cover} alt={milestone.data.title} class="mb-4 max-w-[120px] w-full h-auto rounded-md" />
              )}
              <h3 class="text-lg font-medium leading-snug group-hover:text-accent transition-colors">
                {milestone.data.title}
                {milestone.data.externalUrl && <span class="ml-1 text-text-secondary">↗</span>}
              </h3>
              <p class="mt-1 text-base font-medium leading-relaxed text-text-secondary">{milestone.data.description}</p>
            </div>
          </Tag>
        );
      })}
    </div>
  </section>
  </main>

  <script>
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') history.back();
    });
  </script>
</BaseLayout>
