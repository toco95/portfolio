---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const milestones = await getCollection('milestones');
const sorted = milestones.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function getYear(date: Date) {
  return date.getFullYear().toString();
}
---

<BaseLayout title="Track Record — Thomas Cochet" description="Key milestones in my design career.">
  <section class="py-0">
    <h1 class="text-2xl font-medium">Track Record</h1>
    <p class="mt-2 text-xl text-text-secondary">Key milestones along the way</p>

    <div class="mt-10">
      {sorted.map((milestone) => (
        <div class="grid grid-cols-[80px_1fr] gap-x-8 py-6">
          <time class="text-sm text-text-tertiary pt-0.5">{getYear(milestone.data.date)}</time>

          <div>
            <h3 class="text-lg font-medium leading-snug">
              {milestone.data.externalUrl ? (
                <a
                  href={milestone.data.externalUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-accent transition-colors"
                >
                  {milestone.data.title}
                  <span class="ml-1 text-text-secondary">↗</span>
                </a>
              ) : (
                milestone.data.title
              )}
            </h3>
            <p class="mt-1.5 text-base leading-relaxed text-text-secondary">{milestone.data.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
